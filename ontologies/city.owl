        <rdfs:label xml:lang="en">BridgeFurniture</rdfs:label>
        <skos:definition xml:lang="en">A BridgeFurniture is an equipment for occupant use, usually not fixed to the bridge. [cf. ISO 6707-1]</skos:definition>
    </owl:Class>
    


