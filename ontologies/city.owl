        <rdfs:label xml:lang="en">TransactionTypeValue</rdfs:label>
        <skos:definition xml:lang="en">TransactionTypeValue enumerates the three possible types of transactions: insert, delete, or replace.</skos:definition>
    </owl:Class>
    


    <!-- https://dataset-dl.liris.cnrs.fr/rdf-owl-urban-data-ontologies/Ontologies/CityOWL/CWA/3.0/versioning#Version -->

