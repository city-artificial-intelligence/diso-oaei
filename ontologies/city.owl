    <!-- https://dataset-dl.liris.cnrs.fr/rdf-owl-urban-data-ontologies/Ontologies/CityOWL/CWA/3.0/building#AbstractBuildingSubdivision.sortKey -->

    <owl:DatatypeProperty rdf:about="https://dataset-dl.liris.cnrs.fr/rdf-owl-urban-data-ontologies/Ontologies/CityOWL/CWA/3.0/building#AbstractBuildingSubdivision.sortKey">
        <rdfs:domain rdf:resource="https://dataset-dl.liris.cnrs.fr/rdf-owl-urban-data-ontologies/Ontologies/CityOWL/CWA/3.0/building#AbstractBuildingSubdivision"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
