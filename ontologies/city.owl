        <rdfs:label xml:lang="en">theme</rdfs:label>
        <skos:definition xml:lang="en">Specifies the topic of the Appearance. Each Appearance contains surface data for one theme only. Examples of themes are infrared radiation, noise pollution, or earthquake-induced structural stress.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://dataset-dl.liris.cnrs.fr/rdf-owl-urban-data-ontologies/Ontologies/CityOWL/CWA/3.0/appearance#GeoreferencedTexture.preferWorldFile -->

