        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">BridgeRoom</rdfs:label>
        <skos:definition xml:lang="en">A BridgeRoom is a space within a Bridge or BridgePart intended for human occupancy (e.g. a place of work or recreation) and/or containment (storage) of animals or things. A BridgeRoom is bounded physically and/or virtually (e.g. by ClosureSurfaces or GenericSurfaces).</skos:definition>
    </owl:Class>
    


