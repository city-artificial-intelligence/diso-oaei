    </owl:Class>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix#Report -->

    <owl:Class rdf:about="http://docs.oasis-open.org/ns/cti/stix#Report">
        <rdfs:subClassOf rdf:resource="http://docs.oasis-open.org/ns/cti/stix/core#DomainObject"/>
