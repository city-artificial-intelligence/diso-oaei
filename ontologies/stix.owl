    <!-- http://docs.oasis-open.org/ns/cti/stix/indicator#indicator_types -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/indicator#indicator_types">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#Indicator"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>anomalous-activity</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>anonymization</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
