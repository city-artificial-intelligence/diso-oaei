            <owl:Restriction>
                <owl:onProperty rdf:resource="http://docs.oasis-open.org/ns/cti#confidence"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://docs.oasis-open.org/ns/cti#created_by_ref_id"/>
