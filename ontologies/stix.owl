    <!-- http://docs.oasis-open.org/ns/cti#revoked -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti#revoked">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti#ExtensionDefinition"/>
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/core#DomainObject"/>
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/core#MetaObject"/>
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/core#RelationshipObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en-us">Indicates whether the object has been revoked.\n\nRevoked objects are no longer considered valid by the object creator. Revoking an object is permanent; future versions of the object with this id MUST NOT be created.</rdfs:comment>
        <rdfs:label xml:lang="en-us">revoked</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti#schema -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti#schema">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti#ExtensionDefinition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment xml:lang="en-us">Specifies a URL that points to a JSON schema or a location that contains information about the schema.</rdfs:comment>
        <rdfs:label xml:lang="en-us">schema</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti#source_name -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti#source_name">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti#ExternalReference"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">The name of the source that the external reference is defined within.</rdfs:comment>
        <rdfs:label xml:lang="en-us">source name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti#spec_version -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti#spec_version">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti#ExtensionDefinition"/>
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/data-marking#MarkingDefinition"/>
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/core#Object"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Identifies the version of the specification used to represent this object.</rdfs:comment>
        <rdfs:label xml:lang="en-us">spec_version</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti#start_time -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti#start_time">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#Relationship"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en-us">Represents the earliest date and time at which the Relationship between the objects exists. If this property is a future timestamp, at the time the start_time property is defined, then this represents an estimate by the producer of the intelligence of the earliest time at which relationship will be asserted to be true.\n\nIf it is not specified, then the earliest time at which the relationship between the objects exists is not defined.</rdfs:comment>
        <rdfs:label xml:lang="en-us">start_time</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti#stop_time -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti#stop_time">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#Relationship"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en-us">Specifies the latest date and time at which the Relationship between the objects exists. If this property is a future timestamp, at the time the stop_time property is defined, then this represents an estimate by the producer of the intelligence of the latest time at which relationship will be asserted to be true.\n\nIf start_time and stop_time are both defined, then stop_time MUST be later than the start_time value.\n\nIf stop_time is not specified, then the latest time at which the relationship between the objects exists is either not known, not disclosed, or has no defined stop time.</rdfs:comment>
        <rdfs:label xml:lang="en-us">stop_time</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti#street_address -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti#street_address">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#Location"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">The street address that this Location describes. This property includes all aspects or parts of the street address. For example, some addresses may have multiple lines including a mailstop or apartment number.</rdfs:comment>
        <rdfs:label xml:lang="en-us">street_address</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti#submitted -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti#submitted">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#MalwareAnalysis"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en-us">Specifies the date and time that the entity was first submitted for scanning or analysis. This value will stay constant while the scanned date can change.</rdfs:comment>
        <rdfs:label xml:lang="en-us">submitted</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti#type -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti#type">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti#url -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti#url">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti#ExternalReference"/>
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#Artifact"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment xml:lang="en-us">Specifies a URL reference to an external resource</rdfs:comment>
        <rdfs:label xml:lang="en-us">url</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti#valid_from -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti#valid_from">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#Indicator"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en-us">Specifies the date and time from which this this entity is considered to be valid  for the behaviors it is related or represents.</rdfs:comment>
        <rdfs:label xml:lang="en-us">valid_from</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti#valid_until -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti#valid_until">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#Indicator"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en-us">Specifies the date and time at which this entity should no longer be considered valid for the behaviors it is related to or represents.\n\nIf the valid_until property is omitted, then there is no constraint on the latest time for which the entity is valid.\n\nThis MUST be greater than the timestamp in the valid_from property.</rdfs:comment>
        <rdfs:label xml:lang="en-us">valid_until</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti#vendor -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti#vendor">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#Software"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies the name of the vendor of the software.</rdfs:comment>
        <rdfs:label xml:lang="en-us">vendor</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti#version -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti#version">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti#ExtensionDefinition"/>
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#Software"/>
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#Tool"/>
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#X509Certificate"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies the version of the entity.</rdfs:comment>
        <rdfs:label xml:lang="en-us">version</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/data-marking#definition_type -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/data-marking#definition_type">
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>statement</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>tlp</rdf:first>
                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <rdfs:comment>Specifies the type of Marking Definition.</rdfs:comment>
        <rdfs:label>definition_type</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/data-marking#marking_ref_id -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/data-marking#marking_ref_id">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/data-marking#GranularMarking"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies an identifier to the marking-definition object that describes the marking.\n\nIf the lang property is not present, this property MUST be present. If the lang property is present, this property MUST NOT be present.</rdfs:comment>
        <rdfs:label xml:lang="en-us">marking_ref_id</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/data-marking#object_marking_refs_id -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/data-marking#object_marking_refs_id">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti#ExtensionDefinition"/>
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/data-marking#MarkingDefinition"/>
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/core#Object"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies a list of identifiers to marking-definition objects that apply to this object.\n\nIn some cases, though uncommon, marking definitions themselves may be marked with sharing or handling guidance. In this case, this property MUST NOT contain any references to the same Marking Definition object (i.e., it cannot contain any circular references).</rdfs:comment>
        <rdfs:label xml:lang="en-us">object marking_refs_id</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/data-marking#selectors -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/data-marking#selectors">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/data-marking#GranularMarking"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies a list of selectors for content contained within the Object in which this property appears.\n\nThe marking-definition referenced in the marking_ref property is applied to the content selected by the selectors in this list.\n\nThe [RFC5646] language code specified by the lang property is applied to the content selected by the selectors in this list.</rdfs:comment>
        <rdfs:label xml:lang="en-us">selectors</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/data-marking#statement -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/data-marking#statement">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/data-marking#StatementMarking"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">A Statement (e.g., copyright, terms of use) applied to the content marked by this marking definition.</rdfs:comment>
        <rdfs:label xml:lang="en-us">statement</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/data-marking#tlp -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/data-marking#tlp">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/data-marking#TLPMarking"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>amber</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>green</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>red</rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                <rdf:first>white</rdf:first>
                                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                            </rdf:Description>
                                        </rdf:rest>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <rdfs:comment xml:lang="en-us">Specifies the TLP level [TLP] of the content marked by this marking definition.</rdfs:comment>
        <rdfs:label xml:lang="en-us">tlp</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix#analysis_sco_refs_id -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix#analysis_sco_refs_id">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#MalwareAnalysis"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies the identifiers of STIX Cyber-observable Objects that were captured during the analysis process.</rdfs:comment>
        <rdfs:label xml:lang="en-us">analysis_sco_refs_id</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix#contains_refs_id -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix#contains_refs_id">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#Directory"/>
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#File"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies a list of identifiers of other STIX Cyber Observable Objects contained within the file or directory, such as another file that is appended to the end of the file, or an IP address that is contained somewhere in the file.\n\nThis is intended for use cases other than those targeted by the Archive extension</rdfs:comment>
        <rdfs:label xml:lang="en-us">contains_refs_id</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix#defanged -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix#defanged">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/core#CyberObservable"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en-us">Specifies whether or not the data contained within the object has been defanged.\n\nThis property MUST only be used on STIX Cyber Observable Objects.</rdfs:comment>
        <rdfs:label xml:lang="en-us">defanged</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix#extension_type -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix#extension_type">
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>legacy</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>new-sco</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>new-sdo</rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                <rdf:first>new-sro</rdf:first>
                                                <rdf:rest>
                                                    <rdf:Description>
                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                        <rdf:first>property-extension</rdf:first>
                                                        <rdf:rest>
                                                            <rdf:Description>
                                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                <rdf:first>toplevel-property-extension</rdf:first>
                                                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                                            </rdf:Description>
                                                        </rdf:rest>
                                                    </rdf:Description>
                                                </rdf:rest>
                                            </rdf:Description>
                                        </rdf:rest>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix#kill_chain_name -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix#kill_chain_name">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#AttackPattern"/>
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#KillChainPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies the name of the kill chain.\n\nThe value of this property SHOULD be all lowercase and SHOULD use hyphens instead of spaces or underscores as word separators.@{en-US}</rdfs:comment>
        <rdfs:label xml:lang="en-us">kill_chain_name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix#object_ref_id -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix#object_ref_id">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#LanguageContent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies the identifier of a STIX Object that is referred to by this entity.</rdfs:comment>
        <rdfs:label xml:lang="en-us">object_ref_id</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix#object_refs_id -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix#object_refs_id">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#Grouping"/>
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#Note"/>
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#Opinion"/>
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#Report"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies a list of identifiers of STIX Objects that are referred to by this entity.</rdfs:comment>
        <rdfs:label xml:lang="en-us">object_refs_id</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix#phase_name -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix#phase_name">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#KillChainPhase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies the name of the phase in the kill chain.\n\nThe value of this property SHOULD be all lowercase and SHOULD use hyphens instead of spaces or underscores as word separators.</rdfs:comment>
        <rdfs:label xml:lang="en-us">phase_name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix#sample_ref_id -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix#sample_ref_id">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#MalwareAnalysis"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies the identifier of the Cyber Observable object that this analysis was performed against.</rdfs:comment>
        <rdfs:label xml:lang="en-us">sample_ref_id</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix#sample_refs_id -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix#sample_refs_id">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#Malware"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies a list of identifiers to the Cyber Observable objects associated with this entity.</rdfs:comment>
        <rdfs:label xml:lang="en-us">sample_refs_id</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/adversary#goals -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/adversary#goals">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#InstrusionSet"/>
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#ThreatActor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies the high-level goals of this Intrusion Set, namely, what are they trying to do. For example, they may be motivated by personal gain, but their goal is to steal credit card numbers. To do this, they may execute specific Campaigns that have detailed objectives like compromising point of sale systems at a large retailer.</rdfs:comment>
        <rdfs:label xml:lang="en-us">goals</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/adversary#personal_motivations -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/adversary#personal_motivations">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#ThreatActor"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>accidental</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>coercion</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>dominance</rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                <rdf:first>ideology</rdf:first>
                                                <rdf:rest>
                                                    <rdf:Description>
                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                        <rdf:first>notoriety</rdf:first>
                                                        <rdf:rest>
                                                            <rdf:Description>
                                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                <rdf:first>organizational-gain</rdf:first>
                                                                <rdf:rest>
                                                                    <rdf:Description>
                                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                        <rdf:first>personal-gain</rdf:first>
                                                                        <rdf:rest>
                                                                            <rdf:Description>
                                                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                                <rdf:first>personal-satisfaction</rdf:first>
                                                                                <rdf:rest>
                                                                                    <rdf:Description>
                                                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                                        <rdf:first>revenge</rdf:first>
                                                                                        <rdf:rest>
                                                                                            <rdf:Description>
                                                                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                                                <rdf:first>unpredictable</rdf:first>
                                                                                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                                                                            </rdf:Description>
                                                                                        </rdf:rest>
                                                                                    </rdf:Description>
                                                                                </rdf:rest>
                                                                            </rdf:Description>
                                                                        </rdf:rest>
                                                                    </rdf:Description>
                                                                </rdf:rest>
                                                            </rdf:Description>
                                                        </rdf:rest>
                                                    </rdf:Description>
                                                </rdf:rest>
                                            </rdf:Description>
                                        </rdf:rest>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <rdfs:comment xml:lang="en-us">The personal reasons, motivations, or purposes of the Threat Actor regardless of organizational goals.\n\nPersonal motivation, which is independent of the organization’s goals, describes what impels an individual to carry out an attack. Personal motivation may align with the organization’s motivation—as is common with activists—but more often it supports personal goals. For example, an individual analyst may join a Data Miner corporation because his or her skills may align with the corporation’s objectives. But the analyst most likely performs his or her daily work toward those objectives for personal reward in the form of a paycheck. The motivation of personal reward may be even stronger for Threat Actors who commit illegal acts, as it is more difficult for someone to cross that line purely for altruistic reasons. The position in the list has no significance.\n\nThe values for this property SHOULD come from the attack-motivation-ov open vocabulary.</rdfs:comment>
        <rdfs:label xml:lang="en-us">personal_motivations</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/adversary#primary_motivation -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/adversary#primary_motivation">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#InstrusionSet"/>
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#ThreatActor"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>accidental</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>coercion</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>dominance</rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                <rdf:first>ideology</rdf:first>
                                                <rdf:rest>
                                                    <rdf:Description>
                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                        <rdf:first>notoriety</rdf:first>
                                                        <rdf:rest>
                                                            <rdf:Description>
                                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                <rdf:first>organizational-gain</rdf:first>
                                                                <rdf:rest>
                                                                    <rdf:Description>
                                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                        <rdf:first>personal-gain</rdf:first>
                                                                        <rdf:rest>
                                                                            <rdf:Description>
                                                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                                <rdf:first>personal-satisfaction</rdf:first>
                                                                                <rdf:rest>
                                                                                    <rdf:Description>
                                                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                                        <rdf:first>revenge</rdf:first>
                                                                                        <rdf:rest>
                                                                                            <rdf:Description>
                                                                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                                                <rdf:first>unpredictable</rdf:first>
                                                                                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                                                                            </rdf:Description>
                                                                                        </rdf:rest>
                                                                                    </rdf:Description>
                                                                                </rdf:rest>
                                                                            </rdf:Description>
                                                                        </rdf:rest>
                                                                    </rdf:Description>
                                                                </rdf:rest>
                                                            </rdf:Description>
                                                        </rdf:rest>
                                                    </rdf:Description>
                                                </rdf:rest>
                                            </rdf:Description>
                                        </rdf:rest>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <rdfs:comment xml:lang="en-us">Specifies the primary reason, motivation, or purpose behind this Intrusion Set. The motivation is why the Intrusion Set wishes to achieve the goal (what they are trying to achieve).\n\nThe value for this property SHOULD come from the attack-motivation-ov open vocabulary.</rdfs:comment>
        <rdfs:label xml:lang="en-us">primary_motivation</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/adversary#resource_level -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/adversary#resource_level">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#InstrusionSet"/>
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#ThreatActor"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>club</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>contest</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>government</rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                <rdf:first>individual</rdf:first>
                                                <rdf:rest>
                                                    <rdf:Description>
                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                        <rdf:first>organization</rdf:first>
                                                        <rdf:rest>
                                                            <rdf:Description>
                                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                <rdf:first>team</rdf:first>
                                                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                                            </rdf:Description>
                                                        </rdf:rest>
                                                    </rdf:Description>
                                                </rdf:rest>
                                            </rdf:Description>
                                        </rdf:rest>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <rdfs:comment xml:lang="en-us">Specifies the organizational level at which this Intrusion Set typically works, which in turn determines the resources available to this Intrusion Set for use in an attack.\n\nThe value for this property SHOULD come from the attack-resource-level-ov open vocabulary.</rdfs:comment>
        <rdfs:label xml:lang="en-us">resource_level</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/adversary#roles -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/adversary#roles">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#ThreatActor"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>agent</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>director</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>independent</rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                <rdf:first>infrastructure-architect</rdf:first>
                                                <rdf:rest>
                                                    <rdf:Description>
                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                        <rdf:first>infrastructure-operator</rdf:first>
                                                        <rdf:rest>
                                                            <rdf:Description>
                                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                <rdf:first>malware-author</rdf:first>
                                                                <rdf:rest>
                                                                    <rdf:Description>
                                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                        <rdf:first>sponsor</rdf:first>
                                                                        <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                                                    </rdf:Description>
                                                                </rdf:rest>
                                                            </rdf:Description>
                                                        </rdf:rest>
                                                    </rdf:Description>
                                                </rdf:rest>
                                            </rdf:Description>
                                        </rdf:rest>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <rdfs:comment xml:lang="en-us">Specifies a list of roles the Threat Actor plays.\n\nThe values for this property SHOULD come from the threat-actor-role-ov open vocabulary.</rdfs:comment>
        <rdfs:label xml:lang="en-us">roles</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/adversary#secondary_motivations -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/adversary#secondary_motivations">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#InstrusionSet"/>
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#ThreatActor"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>accidental</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>coercion</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>dominance</rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                <rdf:first>ideology</rdf:first>
                                                <rdf:rest>
                                                    <rdf:Description>
                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                        <rdf:first>notoriety</rdf:first>
                                                        <rdf:rest>
                                                            <rdf:Description>
                                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                <rdf:first>organizational-gain</rdf:first>
                                                                <rdf:rest>
                                                                    <rdf:Description>
                                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                        <rdf:first>personal-gain</rdf:first>
                                                                        <rdf:rest>
                                                                            <rdf:Description>
                                                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                                <rdf:first>personal-satisfaction</rdf:first>
                                                                                <rdf:rest>
                                                                                    <rdf:Description>
                                                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                                        <rdf:first>revenge</rdf:first>
                                                                                        <rdf:rest>
                                                                                            <rdf:Description>
                                                                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                                                <rdf:first>unpredictable</rdf:first>
                                                                                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                                                                            </rdf:Description>
                                                                                        </rdf:rest>
                                                                                    </rdf:Description>
                                                                                </rdf:rest>
                                                                            </rdf:Description>
                                                                        </rdf:rest>
                                                                    </rdf:Description>
                                                                </rdf:rest>
                                                            </rdf:Description>
                                                        </rdf:rest>
                                                    </rdf:Description>
                                                </rdf:rest>
                                            </rdf:Description>
                                        </rdf:rest>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <rdfs:comment xml:lang="en-us">Specifies the secondary reasons, motivations, or purposes behind this Intrusion Set. These motivations can exist as an equal or near-equal cause to the primary motivation. However, it does not replace or necessarily magnify the primary motivation, but it might indicate additional context. The position in the list has no significance.\n\nThe values for this property SHOULD come from the attack-motivation-ov open vocabulary.</rdfs:comment>
        <rdfs:label xml:lang="en-us">secondary_motivations</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/adversary#sophistication -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/adversary#sophistication">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#ThreatActor"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>advanced</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>expert</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>innovator</rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                <rdf:first>intermediate</rdf:first>
                                                <rdf:rest>
                                                    <rdf:Description>
                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                        <rdf:first>minimal</rdf:first>
                                                        <rdf:rest>
                                                            <rdf:Description>
                                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                <rdf:first>none</rdf:first>
                                                                <rdf:rest>
                                                                    <rdf:Description>
                                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                        <rdf:first>strategic</rdf:first>
                                                                        <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                                                    </rdf:Description>
                                                                </rdf:rest>
                                                            </rdf:Description>
                                                        </rdf:rest>
                                                    </rdf:Description>
                                                </rdf:rest>
                                            </rdf:Description>
                                        </rdf:rest>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <rdfs:comment xml:lang="en-us">Specifies the skill, specific knowledge, special training, or expertise a Threat Actor must have to perform the attack.\n\nThe value for this property SHOULD come from the threat-actor-sophistication-ov open vocabulary.</rdfs:comment>
        <rdfs:label xml:lang="en-us">sophistication</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/adversary#threat_actor_types -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/adversary#threat_actor_types">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#ThreatActor"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>activist</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>competitor</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>crime-syndicate</rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                <rdf:first>criminal</rdf:first>
                                                <rdf:rest>
                                                    <rdf:Description>
                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                        <rdf:first>hacker</rdf:first>
                                                        <rdf:rest>
                                                            <rdf:Description>
                                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                <rdf:first>insider-accidential</rdf:first>
                                                                <rdf:rest>
                                                                    <rdf:Description>
                                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                        <rdf:first>insider-disgruntled</rdf:first>
                                                                        <rdf:rest>
                                                                            <rdf:Description>
                                                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                                <rdf:first>nation-state</rdf:first>
                                                                                <rdf:rest>
                                                                                    <rdf:Description>
                                                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                                        <rdf:first>sensationalist</rdf:first>
                                                                                        <rdf:rest>
                                                                                            <rdf:Description>
                                                                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                                                <rdf:first>spy</rdf:first>
                                                                                                <rdf:rest>
                                                                                                    <rdf:Description>
                                                                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                                                        <rdf:first>terrorist</rdf:first>
                                                                                                        <rdf:rest>
                                                                                                            <rdf:Description>
                                                                                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                                                                <rdf:first>unknown</rdf:first>
                                                                                                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                                                                                            </rdf:Description>
                                                                                                        </rdf:rest>
                                                                                                    </rdf:Description>
                                                                                                </rdf:rest>
                                                                                            </rdf:Description>
                                                                                        </rdf:rest>
                                                                                    </rdf:Description>
                                                                                </rdf:rest>
                                                                            </rdf:Description>
                                                                        </rdf:rest>
                                                                    </rdf:Description>
                                                                </rdf:rest>
                                                            </rdf:Description>
                                                        </rdf:rest>
                                                    </rdf:Description>
                                                </rdf:rest>
                                            </rdf:Description>
                                        </rdf:rest>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <rdfs:comment xml:lang="en-us">Specifies the type(s) of this threat actor.\n\nThe values for this property SHOULD come from the threat-actor-type-ov open vocabulary.</rdfs:comment>
        <rdfs:label xml:lang="en-us">threat_actor_types</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/artifact#decryption_key -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/artifact#decryption_key">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#Artifact"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies the decryption key for the encrypted binary data (either via payload_bin or url). For example, this may be useful in cases of sharing malware samples, which are often encoded in an encrypted archive.\n\nThis property MUST NOT be present when the encryption_algorithm property is absent.</rdfs:comment>
        <rdfs:label xml:lang="en-us">decryption_key</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/artifact#encryption_algorithm -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/artifact#encryption_algorithm">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#Artifact"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>AES-256-GCM</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>ChaCha20-Poly1035</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>mime-type-indicated</rdf:first>
                                        <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <rdfs:comment xml:lang="en-us">Specifies the type of encryption algorithm the binary data (either via payload_bin or url) is encoded in, if the artifact is encrypted.\n\nIf both mime_type and encryption_algorithm are included, this signifies that the artifact represents an encrypted archive.</rdfs:comment>
        <rdfs:label xml:lang="en-us">encryption algorithm</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/artifact#payload_bin -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/artifact#payload_bin">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#Artifact"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#base64Binary"/>
        <rdfs:comment xml:lang="en-us">Specifies the binary data contained in the artifact as a base64-encoded string.\n\nThis property MUST NOT be present if url is provided.</rdfs:comment>
        <rdfs:label xml:lang="en-us">payload_bin</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/autonomous-system#number -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/autonomous-system#number">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#AutonomousSystem"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
        <rdfs:comment xml:lang="en-us">Specifies the number assigned to the AS. Such assignments are typically performed by a Regional Internet Registry (RIR).</rdfs:comment>
        <rdfs:label xml:lang="en-us">number</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/autonomous-system#rir -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/autonomous-system#rir">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#AutonomousSystem"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies the name of the Regional Internet Registry (RIR) that assigned the number to the AS.</rdfs:comment>
        <rdfs:label xml:lang="en-us">rir</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/campaign#objective -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/campaign#objective">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#Campaign"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies the Campaign’s primary goal, objective, desired outcome, or intended effect — what the Threat Actor or Intrusion Set hopes to accomplish with this Campaign.</rdfs:comment>
        <rdfs:label xml:lang="en-us">objective</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/directory#path -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/directory#path">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#Directory"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies the path, as originally observed, to the directory on the file system.</rdfs:comment>
        <rdfs:label xml:lang="en-us">path</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/directory#path_enc -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/directory#path_enc">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#Directory"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies the observed encoding for the path. The value MUST be specified if the path is stored in a non-Unicode encoding. This value MUST be specified using the corresponding name from the 2013-12-20 revision of the IANA character set registry. If the preferred MIME name for a character set is defined, this value MUST be used; if it is not defined, then the Name value from the registry MUST be used instead.</rdfs:comment>
        <rdfs:label xml:lang="en-us">path_enc</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/domain-name#resolves_to_refs_id -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/domain-name#resolves_to_refs_id">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#DomainName"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies a list of identifiers to one or more SCO IP Address or Domain Name objectss that the domain name resolves to.\n\nThe object identifiers referenced in this list MUST be for objects of type ipv4-addr or ipv6-addr or domain-name (for cases such as CNAME records).</rdfs:comment>
        <rdfs:label xml:lang="en-us">resolved_to_refs_id</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/domain-name#value -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/domain-name#value">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#DomainName"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies the value of the domain name.\n\nThe value of this property MUST conform to [RFC1034], and each domain and sub-domain contained within the domain name MUST conform to [RFC5890].</rdfs:comment>
        <rdfs:label xml:lang="en-us">value</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/email-address#belongs_to_ref_id -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/email-address#belongs_to_ref_id">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#EmailAddress"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies the identifier of the SCO UserAccount object that the email address belongs to.\n\nThe object referenced in this property MUST be of type user-account.</rdfs:comment>
        <rdfs:label xml:lang="en-us">belongs_to_ref_id</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/email-address#display_name -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/email-address#display_name">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#EmailAddress"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies a single email display name, i.e., the name that is displayed to the human user of a mail application.</rdfs:comment>
        <rdfs:label xml:lang="en-us">display_name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/email-address#value -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/email-address#value">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#EmailAddress"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies the value of the email address. This MUST NOT include the display name.\n\nThis property corresponds to the addr-spec construction in section 3.4 of RFC5322, for example, jane.smith@example.com.</rdfs:comment>
        <rdfs:label xml:lang="en-us">value</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/archive-file#comment -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/archive-file#comment">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/archive-file#ArchiveFile"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies a comment included as part of the associated entity.</rdfs:comment>
        <rdfs:label xml:lang="en-us">comment</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/archive-file#contains_refs_id -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/archive-file#contains_refs_id">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/archive-file#ArchiveFile"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies a list of identifiers of other STIX Cyber Observable Objects contained within the file or directory, such as another file that is appended to the end of the file, or an IP address that is contained somewhere in the file.\n\nThis is intended for use cases other than those targeted by the Archive extension</rdfs:comment>
        <rdfs:label xml:lang="en-us">contains_refs_id</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_ACCEPTCONN -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_ACCEPTCONN">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies whether or not this socket has been marked to accept connections with listen(2).</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_ACCEPTCONN</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_ATTACH_BPF -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_ATTACH_BPF">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies whether an extended BPF program is attached to the socket for use as a filter of incoming packets.</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_ATTACH_BPF</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_ATTACH_FILTER -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_ATTACH_FILTER">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies whether a classic BPF program is attached to the socket for use as a filter of incoming packets.</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_ATTACH_FILTER</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_ATTACH_REUSEPORT_CBPF -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_ATTACH_REUSEPORT_CBPF">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specific a classic BPF program which defines how packets are assigned to the sockets in the reuseport group</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_ATTACH_REUSEPORT_CBPF</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_ATTACH_REUSEPORT_EBPF -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_ATTACH_REUSEPORT_EBPF">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies a extended EBPF program which defines how packets are assigned to the sockets in the reuseport group</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_ATTACH_REUSEPORT_EBPF</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_BINDTODEVICE -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_BINDTODEVICE">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies whether this socket is bound to a particular device like \“eth0\”, as specified in the passed interface name.</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_BINDTODEVICE</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_BROADCAST -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_BROADCAST">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies whether the broadcast flag.</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_BROADCAST</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_BSDCOMPAT -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_BSDCOMPAT">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies whether BSD bug-to-bug compatibility is enabled.</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_BSDCOMPAT</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_BUSY_POLL -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_BUSY_POLL">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies the approximate time in microseconds to busy poll on a blocking receive when there is no data.</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_BUSY_POLL</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_DEBUG -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_DEBUG">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies whether socket debugging is enabled.  Allowed only for processes with the CAP_NET_ADMIN capability or an effective user ID of 0.</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_DEBUG</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_DETACH_BPF -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_DETACH_BPF">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies whether to remove the extended BPF program attached to a socket with either SO_ATTACH_FILTER or SO_ATTACH_BPF.</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_DETACH_FILTER</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_DETACH_FILTER -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_DETACH_FILTER">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies whether to remove the classic BPF program attached to a socket with either SO_ATTACH_FILTER or SO_ATTACH_BPF.</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_DETACH_FILTER</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_DOMAIN -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_DOMAIN">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies the socket domain as an integer, returning a value such as AF_INET6.</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_DOMAIN</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_DONTROUTE -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_DONTROUTE">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies not send via a gateway, send only to directly connected hosts.</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_DOUNTROUTE</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_ERROR -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_ERROR">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies whether there is a pending socket error.</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_ERROR</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_INCOMING_CPU -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_INCOMING_CPU">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies the CPU affinity of a socket.  Expects an integer flag.</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_INCOMING_CPU</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_INCOMING_NAPI_ID -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_INCOMING_NAPI_ID">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies whether a system-level unique ID called NAPI ID that is associated with a RX queue on which the last packet associated with that socket is received.</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_INCOMING_NAPI_ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_KEEPALIVE -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_KEEPALIVE">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies whether sending of keep-alive messages on connection-oriented sockets is performed.  Expects an integer boolean flag.</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_KEEPALIVE</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_LINGER -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_LINGER">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies whether a close(2) or shutdown(2) will not return until all queued messages for the socket have been successfully sent or the linger timeout has been reached.</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_LINGER</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_LOCK_FILTER -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_LOCK_FILTER">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies whether prevent changing the filters associated with the socket is prevented.</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_LOCK_FILTER</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_MARK -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_MARK">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies wehther the mark for each packet sent through this socket (similar to the netfilter MARK target but socket-based).</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_MARK</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_OOBINLINE -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_OOBINLINE">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies whether out-of-band data is directly placed into the receive data stream.</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_OOBINLINE</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_PASSCRED -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_PASSCRED">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies whether the receiving of the SCM_CREDENTIALS control message is enabled or disbled.</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_PASSCRED</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_PASSSEC -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_PASSSEC">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies whether the receiving of the SCM_SECURITY control message is enabled or disbled.</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_PASSSEC</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_PEEK_OFF -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_PEEK_OFF">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies the value of the &quot;peek offset&quot; for the recv(2) system call when used with MSG_PEEK flag.</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_PEEK_OFF</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_PEERCRED -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_PEERCRED">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies the credentials of the peer process connected to this socket.</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_PEERCRED</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_PEERSEC -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_PEERSEC">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies the security context of the peer socket connected to this socket.</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_PEERSEC</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_PRIORITY -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_PRIORITY">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies the protocol-defined priority for all packets to be sent on this socket.</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_PRIORITY</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_PROTOCOL -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_PROTOCOL">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies the socket protocol as an integer, returning a value such as IPPROTO_SCTP.</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_PROTOCOL</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_RCVBUF -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_RCVBUF">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies the maximum socket receive buffer in bytes.  The kernel doubles this value (to allow space for bookkeeping overhead) when it is set using setsockopt(2), and this doubled value is returned by getsockopt(2).</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_RCVBUF</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_RCVBUFFORCE -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_RCVBUFFORCE">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies whether a privileged (CAP_NET_ADMIN) process can perform the same task as SO_RCVBUF, but the rmem_max limit can be overridden.</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_RECBUFFORCE</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_RCVLOWAT -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_RCVLOWAT">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specify the minimum number of bytes in the buffer until the socket layer will pass the data the user on receiving.</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_RCVLOWAT</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_RCVTIMEO -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_RCVTIMEO">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies whether receiving timeouts until reporting an error.</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_RCVTIMEO</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_REUSEADDR -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_REUSEADDR">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies whether the rules used in validating addresses supplied in a bind(2) call should allow reuse of local addresses.</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_REUSEADDR</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_REUSEPORT -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_REUSEPORT">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies whether multiple AF_INET or AF_INET6 sockets are permitted to be bound to an identical socket address.</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_REUSEPORT</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_RXQ_OVFL -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_RXQ_OVFL">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies that an unsigned 32-bit value ancillary message (cmsg) should be attached to received skbs indicating the number of packets dropped by the socket since its creation.</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_RXQ_OVFL</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_SELECT_ERR_QUEUE -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_SELECT_ERR_QUEUE">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies whether an error condition on a socket causes notification not only via the exceptfds set of select(2).</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_SELECT_ERR_QUEUE</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_SNDBUF -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_SNDBUF">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies the maximum socket send buffer in bytes.</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_SNDBUF</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_SNDBUFFORCE -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_SNDBUFFORCE">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies a privileged (CAP_NET_ADMIN) process can perform the same task as SO_SNDBUF, but the wmem_max limit can be overridden.</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_SNDBUFFORCE</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_SNDLOWAT -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_SNDLOWAT">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specify the minimum number of bytes in the buffer until the socket layer will pass the data to the protocol</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_SNDLOWAT</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_SNDTIMEO -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_SNDTIMEO">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies whether sending timeouts until reporting an error.</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_SNDTIMEO</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_TIMESTAMP -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_TIMESTAMP">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies whether the receiving of the SO_TIMESTAMP control message is enabled or disabled.</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_TIMESTAMP</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_TIMESTAMPNS -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_TIMESTAMPNS">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies whether the receiving of the SO_TIMESTAMPNS control message are enabled or disabled.</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_TIMESTAMPNS</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_TYPE -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SO_TYPE">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#SocketOptions"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en-us">Specifies the socket type as an integer</rdfs:comment>
        <rdfs:label xml:lang="en-us">SO_TYPE</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#address_family -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#address_family">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#NetworkSocket"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>AF_APPLETALK</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>AF_BTH</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>AF_INET</rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                <rdf:first>AF_INET6</rdf:first>
                                                <rdf:rest>
                                                    <rdf:Description>
                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                        <rdf:first>AF_IPX</rdf:first>
                                                        <rdf:rest>
                                                            <rdf:Description>
                                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                <rdf:first>AF_IRDA</rdf:first>
                                                                <rdf:rest>
                                                                    <rdf:Description>
                                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                        <rdf:first>AF_NETBIOS</rdf:first>
                                                                        <rdf:rest>
                                                                            <rdf:Description>
                                                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                                <rdf:first>AF_UNSPEC</rdf:first>
                                                                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                                                            </rdf:Description>
                                                                        </rdf:rest>
                                                                    </rdf:Description>
                                                                </rdf:rest>
                                                            </rdf:Description>
                                                        </rdf:rest>
                                                    </rdf:Description>
                                                </rdf:rest>
                                            </rdf:Description>
                                        </rdf:rest>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <rdfs:comment xml:lang="en-us">Specifies the address family (AF_*) that the socket is configured for. The values of this property MUST come from the network-socket-address-family-enum enumeration.</rdfs:comment>
        <rdfs:label xml:lang="en-us">address_family</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#dst_flags_hex -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#dst_flags_hex">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#TcpNetworkTraffic"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#hexBinary"/>
        <rdfs:comment xml:lang="en-us">Specifies the destination TCP flags, as the union of all TCP flags observed between the start of the traffic (as defined by the start property) and the end of the traffic (as defined by the end property).\n\nIf the start and end times of the traffic are not specified, this property SHOULD be interpreted as the union of all TCP flags observed over the entirety of the network traffic being reported upon.</rdfs:comment>
        <rdfs:label xml:lang="en-us">dst_flags_hex</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#icmp_code_hex -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#icmp_code_hex">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#IcmpNetworkTraffic"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#hexBinary"/>
        <rdfs:comment xml:lang="en-us">Specifies the ICMP code byte.</rdfs:comment>
        <rdfs:label xml:lang="en-us">icmp_code_hex</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#icmp_type_hex -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#icmp_type_hex">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#IcmpNetworkTraffic"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#hexBinary"/>
        <rdfs:comment xml:lang="en-us">Specifies the ICMP type byte.</rdfs:comment>
        <rdfs:label xml:lang="en-us">icmp_type_hex</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#is_blocking -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#is_blocking">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#NetworkSocket"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en-us">Specifies whether the socket is in blocking mode.</rdfs:comment>
        <rdfs:label xml:lang="en-us">is_blocking</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#is_listening -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#is_listening">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#NetworkSocket"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en-us">Specifies whether the socket is in listening mode.</rdfs:comment>
        <rdfs:label xml:lang="en-us">is_listening</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#message_body_data_ref_id -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#message_body_data_ref_id">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#HttpRequest"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies the identifier of an Artifact object that contains the data contained in the HTTP message body, if included.\n\nThe identifier of the object specified MUST be of type artifact.</rdfs:comment>
        <rdfs:label xml:lang="en-us">message_body_data_ref_id</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#message_body_length -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#message_body_length">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#HttpRequest"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en-us">Specifies the length of the HTTP message body, if included, in bytes.</rdfs:comment>
        <rdfs:label xml:lang="en-us">message_body_length</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#request_method -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#request_method">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#HttpRequest"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>delete</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>get</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>patch</rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                <rdf:first>post</rdf:first>
                                                <rdf:rest>
                                                    <rdf:Description>
                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                        <rdf:first>put</rdf:first>
                                                        <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                                    </rdf:Description>
                                                </rdf:rest>
                                            </rdf:Description>
                                        </rdf:rest>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <rdfs:comment xml:lang="en-us">Specifies the HTTP method portion of the HTTP request line, as a lowercase string.</rdfs:comment>
        <rdfs:label xml:lang="en-us">request_method</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#request_value -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#request_value">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#HttpRequest"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies the value (typically a resource path) portion of the HTTP request line.</rdfs:comment>
        <rdfs:label xml:lang="en-us">request_value</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#request_version -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#request_version">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#HttpRequest"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies the HTTP version portion of the HTTP request line, as a lowercase string.</rdfs:comment>
        <rdfs:label xml:lang="en-us">request_version</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#socket_descriptor -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#socket_descriptor">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#NetworkSocket"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
        <rdfs:comment xml:lang="en-us">Specifies the socket file descriptor value associated with the socket, as a non-negative integer.</rdfs:comment>
        <rdfs:label xml:lang="en-us">socket_descriptor</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#socket_handle -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#socket_handle">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#NetworkSocket"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
        <rdfs:comment xml:lang="en-us">Specifies the handle or inode value associated with the socket.</rdfs:comment>
        <rdfs:label xml:lang="en-us">socket_handle</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#socket_type -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#socket_type">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#NetworkSocket"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>SOCK_DGRAM</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>SOCK_RAW</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>SOCK_RDM</rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                <rdf:first>SOCK_SEQPACKET</rdf:first>
                                                <rdf:rest>
                                                    <rdf:Description>
                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                        <rdf:first>SOCK_STREAM</rdf:first>
                                                        <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                                    </rdf:Description>
                                                </rdf:rest>
                                            </rdf:Description>
                                        </rdf:rest>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <rdfs:comment xml:lang="en-us">Specifies the type of the socket.\n\nThe values of this property MUST come from the network-socket-type-enum enumeration.</rdfs:comment>
        <rdfs:label xml:lang="en-us">socket_type</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#src_flags_hex -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#src_flags_hex">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/network-traffic#TcpNetworkTraffic"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#hexBinary"/>
        <rdfs:comment xml:lang="en-us">Specifies the source TCP flags, as the union of all TCP flags observed between the start of the traffic (as defined by the start property) and the end of the traffic (as defined by the end property).\n\nIf the start and end times of the traffic are not specified, this property SHOULD be interpreted as the union of all TCP flags observed over the entirety of the network traffic being reported upon.</rdfs:comment>
        <rdfs:label xml:lang="en-us">src_flags_hex</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/ntfs-file#sid -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/ntfs-file#sid">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/ntfs-file#NtfsFile"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies the Windows Security ID (SID) value</rdfs:comment>
        <rdfs:label xml:lang="en-us">sid</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/pdf-file#is_optimized -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/pdf-file#is_optimized">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/pdf-file#PDFFile"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en-us">Specifies whether the PDF file has been optimized.</rdfs:comment>
        <rdfs:label xml:lang="en-us">is_optimized</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/pdf-file#pdfid0 -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/pdf-file#pdfid0">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/pdf-file#PDFFile"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies the first file identifier found for the PDF file.</rdfs:comment>
        <rdfs:label xml:lang="en-us">pdfid0</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/pdf-file#pdfid1 -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/pdf-file#pdfid1">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/pdf-file#PDFFile"/>
        <rdfs:comment xml:lang="en-us">Specifies the second file identifier found for the PDF file.</rdfs:comment>
        <rdfs:label xml:lang="en-us">pdfid1</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/pdf-file#version -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/pdf-file#version">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/pdf-file#PDFFile"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies the version of the entity.</rdfs:comment>
        <rdfs:label xml:lang="en-us">version</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/process#aslr_enabled -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/process#aslr_enabled">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en-us">Specifies whether Address Space Layout Randomization (ASLR) is enabled for the process.</rdfs:comment>
        <rdfs:label xml:lang="en-us">aslr_enabled</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/process#cb -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/process#cb">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en-us">Specifies the size of the structure, in bytes.</rdfs:comment>
        <rdfs:label xml:lang="en-us">cb</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/process#dep_enabled -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/process#dep_enabled">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en-us">Specifies whether Data Execution Prevention (DEP) is enabled for the process.</rdfs:comment>
        <rdfs:label xml:lang="en-us">dep_enabled</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/process#descriptions -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/process#descriptions">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies the descriptions defined for the service.</rdfs:comment>
        <rdfs:label xml:lang="en-us">descriptions</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/process#display_name -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/process#display_name">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies the display name of the service in Windows GUI controls.</rdfs:comment>
        <rdfs:label xml:lang="en-us">display_name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/process#dwFillAttribute -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/process#dwFillAttribute">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en-us">If dwFlags specifies STARTF_USEFILLATTRIBUTE, this member is the initial text and background colors if a new console window is created in a console application. Otherwise, this member is ignored</rdfs:comment>
        <rdfs:label xml:lang="en-us">dwFillAttribute</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/process#dwFlags -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/process#dwFlags">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#hexBinary"/>
        <rdfs:comment xml:lang="en-us">A bitfield that determines whether certain STARTUPINFO members are used when the process creates a window.</rdfs:comment>
        <rdfs:label xml:lang="en-us">dwFlags</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/process#dwX -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/process#dwX">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en-us">If dwFlags specifies STARTF_USEPOSITION, this member is the x offset of the upper left corner of a window if a new window is created, in pixels. Otherwise, this member is ignored.\n\nThe offset is from the upper left corner of the screen. For GUI processes, the specified position is used the first time the new process calls CreateWindow to create an overlapped window if the x parameter of CreateWindow is CW_USEDEFAULT.</rdfs:comment>
        <rdfs:label xml:lang="en-us">dwX</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/process#dwXCountChars -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/process#dwXCountChars">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en-us">If dwFlags specifies STARTF_USECOUNTCHARS, if a new console window is created in a console process, this member specifies the screen buffer width, in character columns. Otherwise, this member is ignored.</rdfs:comment>
        <rdfs:label xml:lang="en-us">dwXCountChars</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/process#dwXSize -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/process#dwXSize">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en-us">If dwFlags specifies STARTF_USESIZE, this member is the width of the window if a new window is created, in pixels. Otherwise, this member is ignored.\n\nFor GUI processes, this is used only the first time the new process calls CreateWindow to create an overlapped window if the nWidth parameter of CreateWindow is CW_USEDEFAULT.</rdfs:comment>
        <rdfs:label xml:lang="en-us">dwXSize</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/process#dwY -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/process#dwY">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en-us">If dwFlags specifies STARTF_USEPOSITION, this member is the y offset of the upper left corner of a window if a new window is created, in pixels. Otherwise, this member is ignored.\n\nThe offset is from the upper left corner of the screen. For GUI processes, the specified position is used the first time the new process calls CreateWindow to create an overlapped window if the y parameter of CreateWindow is CW_USEDEFAULT.</rdfs:comment>
        <rdfs:label xml:lang="en-us">dwY</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/process#dwYCountChars -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/process#dwYCountChars">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en-us">If dwFlags specifies STARTF_USECOUNTCHARS, if a new console window is created in a console process, this member specifies the screen buffer height, in character rows. Otherwise, this member is ignored.</rdfs:comment>
        <rdfs:label xml:lang="en-us">dwYCountChars</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/process#dwYSize -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/process#dwYSize">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en-us">If dwFlags specifies STARTF_USESIZE, this member is the height of the window if a new window is created, in pixels. Otherwise, this member is ignored.\n\nFor GUI processes, this is used only the first time the new process calls CreateWindow to create an overlapped window if the nHeight parameter of CreateWindow is CW_USEDEFAULT.</rdfs:comment>
        <rdfs:label xml:lang="en-us">dwYSize</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/process#group_name -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/process#group_name">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies the name of the load ordering group of which the service is a member.</rdfs:comment>
        <rdfs:label xml:lang="en-us">group_name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/process#hStdError -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/process#hStdError">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#hexBinary"/>
        <rdfs:comment xml:lang="en-us">If dwFlags specifies STARTF_USESTDHANDLES, this member is the standard error handle for the process. Otherwise, this member is ignored and the default for standard error is the console window&apos;s buffer.</rdfs:comment>
        <rdfs:label xml:lang="en-us">hStdError</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/process#hStdInput -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/process#hStdInput">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#hexBinary"/>
        <rdfs:comment xml:lang="en-us">If dwFlags specifies STARTF_USESTDHANDLES, this member is the standard input handle for the process. If STARTF_USESTDHANDLES is not specified, the default for standard input is the keyboard buffer.\n\nIf dwFlags specifies STARTF_USEHOTKEY, this member specifies a hotkey value that is sent as the wParam parameter of a WM_SETHOTKEY message to the first eligible top-level window created by the application that owns the process. If the window is created with the WS_POPUP window style, it is not eligible unless the WS_EX_APPWINDOW extended window style is also set. For more information, see CreateWindowEx.\n\nOtherwise, this member is ignored.</rdfs:comment>
        <rdfs:label xml:lang="en-us">hStdInput</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/process#hStdOutput -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/process#hStdOutput">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#hexBinary"/>
        <rdfs:comment xml:lang="en-us">If dwFlags specifies STARTF_USESTDHANDLES, this member is the standard output handle for the process. Otherwise, this member is ignored and the default for standard output is the console window&apos;s buffer.\n\nIf a process is launched from the taskbar or jump list, the system sets hStdOutput to a handle to the monitor that contains the taskbar or jump list used to launch the process. For more information, see Remarks.Windows 7, Windows Server 2008 R2, Windows Vista, Windows Server 2008, Windows XP and Windows Server 2003:  This behavior was introduced in Windows 8 and Windows Server 2012.</rdfs:comment>
        <rdfs:label xml:lang="en-us">hStdOutput</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/process#integrity_level -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/process#integrity_level">
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>high</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>low</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>medium</rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                <rdf:first>system</rdf:first>
                                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                            </rdf:Description>
                                        </rdf:rest>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <rdfs:comment xml:lang="en-us">Specifies the Windows integrity level, or trustworthiness, of the process.\n\nThe values of this property MUST come from the windows-integrity-level-enum enumeration.</rdfs:comment>
        <rdfs:label xml:lang="en-us">integrity_level</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/process#lpDesktop -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/process#lpDesktop">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies the name of the desktop, or the name of both the desktop and window station for this process.  A backslash in the string indicates that the string includes both the desktop and window station names.</rdfs:comment>
        <rdfs:label xml:lang="en-us">lpDesktop</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/process#lpTitle -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/process#lpTitle">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">For console processes, specifies the title displayed in the title bar if a new console window is created. If NULL, the name of the executable file is used as the window title instead. This parameter must be NULL for GUI or console processes that do not create a new console window.</rdfs:comment>
        <rdfs:label xml:lang="en-us">lpTitle</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/process#owner_sid -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/process#owner_sid">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies the Security ID (SID) value of the owner of the process.</rdfs:comment>
        <rdfs:label xml:lang="en-us">owner_sid</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/process#priority -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/process#priority">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies the current priority class of the process in Windows.\n\nThis value SHOULD be a string that ends in _CLASS.</rdfs:comment>
        <rdfs:label xml:lang="en-us">priority</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/process#service_dll_refs_id -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/process#service_dll_refs_id">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies a list of identifiers of File objects that represent the DLLs loaded by the service.\n\nThe identifiers of objects specified  MUST be of type file.</rdfs:comment>
        <rdfs:label xml:lang="en-us">service_dll_refs_id</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/process#service_name -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/process#service_name">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies the name of the service.</rdfs:comment>
        <rdfs:label xml:lang="en-us">service_name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/process#service_status -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/process#service_status">
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>SERVICE_CONTINUE_PENDING</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>SERVICE_PAUSED</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>SERVICE_PAUSE_PENDING</rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                <rdf:first>SERVICE_RUNNING</rdf:first>
                                                <rdf:rest>
                                                    <rdf:Description>
                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                        <rdf:first>SERVICE_START_PENDING</rdf:first>
                                                        <rdf:rest>
                                                            <rdf:Description>
                                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                <rdf:first>SERVICE_STOPPED</rdf:first>
                                                                <rdf:rest>
                                                                    <rdf:Description>
                                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                        <rdf:first>SERVICE_STOP_PENDING</rdf:first>
                                                                        <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                                                    </rdf:Description>
                                                                </rdf:rest>
                                                            </rdf:Description>
                                                        </rdf:rest>
                                                    </rdf:Description>
                                                </rdf:rest>
                                            </rdf:Description>
                                        </rdf:rest>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <rdfs:comment xml:lang="en-us">Specifies the current status of the service.\n\nThe values of this property MUST come from the windows-service-status-enum enumeration.</rdfs:comment>
        <rdfs:label xml:lang="en-us">service_status</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/process#service_type -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/process#service_type">
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>SERVICE_FILE_SYSTEM_DRIVER</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>SERVICE_KERNEL_DRIVER</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>SERVICE_WIN32_OWN_PROCESS</rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                <rdf:first>SERVICE_WIN32_SHARE_PROCESS</rdf:first>
                                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                            </rdf:Description>
                                        </rdf:rest>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <rdfs:comment xml:lang="en-us">Specifies the type of the service.\n\nThe values of this property MUST come from the windows-service-type-enum enumeration.</rdfs:comment>
        <rdfs:label xml:lang="en-us">service_type</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/process#start_type -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/process#start_type">
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>SERVICE_AUTO_START</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>SERVICE_BOOT_START</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>SERVICE_DEMAND_START</rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                <rdf:first>SERVICE_DISABLED</rdf:first>
                                                <rdf:rest>
                                                    <rdf:Description>
                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                        <rdf:first>SERVICE_SYSTEM_ALERT</rdf:first>
                                                        <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                                    </rdf:Description>
                                                </rdf:rest>
                                            </rdf:Description>
                                        </rdf:rest>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <rdfs:comment xml:lang="en-us">Specifies the start options defined for the service.\n\nThe values of this property MUST come from the windows-service-start-type-enum enumeration.</rdfs:comment>
        <rdfs:label xml:lang="en-us">start_type</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/process#wShowWindow -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/process#wShowWindow">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en-us">If dwFlags specifies STARTF_USESHOWWINDOW, this member can be any of the values that can be specified in the nCmdShow parameter for the ShowWindow function, except for SW_SHOWDEFAULT. Otherwise, this member is ignored.\n\nFor GUI processes, the first time ShowWindow is called, its nCmdShow parameter is ignored wShowWindow specifies the default value. In subsequent calls to ShowWindow, the wShowWindow member is used if the nCmdShow parameter of ShowWindow is set to SW_SHOWDEFAULT.</rdfs:comment>
        <rdfs:label xml:lang="en-us">wShowWindow</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/process#windows_title -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/process#windows_title">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies the title of the main window of the process.</rdfs:comment>
        <rdfs:label xml:lang="en-us">windows_title</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/raster-image-file#bits_per_pixel -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/raster-image-file#bits_per_pixel">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/raster-image-file#RasterImageFile"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
        <rdfs:comment xml:lang="en-us">Specifies the sum of bits used for each color channel in the image file, and thus the total number of pixels used for expressing the color depth of the image.</rdfs:comment>
        <rdfs:label xml:lang="en-us">bits_per_pixel</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/raster-image-file#image_height -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/raster-image-file#image_height">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/raster-image-file#RasterImageFile"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
        <rdfs:comment xml:lang="en-us">Specifies the height of the image in the image file, in pixels.</rdfs:comment>
        <rdfs:label xml:lang="en-us">image_height</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/raster-image-file#image_width -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/raster-image-file#image_width">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/raster-image-file#RasterImageFile"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
        <rdfs:comment xml:lang="en-us">Specifies the width of the image in the image file, in pixels.</rdfs:comment>
        <rdfs:label xml:lang="en-us">image width</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/unix-user-account#gid -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/unix-user-account#gid">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/unix-user-account#UnixUserAccount"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
        <rdfs:comment xml:lang="en-us">Specifies the primary group ID of the account.</rdfs:comment>
        <rdfs:label xml:lang="en-us">gid</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/unix-user-account#groups -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/unix-user-account#groups">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/unix-user-account#UnixUserAccount"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies a list of names of groups that the account is a member of.</rdfs:comment>
        <rdfs:label xml:lang="en-us">groups</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/unix-user-account#home_dir -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/unix-user-account#home_dir">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/unix-user-account#UnixUserAccount"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies the home directory of the account.</rdfs:comment>
        <rdfs:label xml:lang="en-us">home_dir</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/unix-user-account#shell -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/unix-user-account#shell">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/unix-user-account#UnixUserAccount"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies the account’s command shell.</rdfs:comment>
        <rdfs:label xml:lang="en-us">shell</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#address_of_entry_point -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#address_of_entry_point">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPEOptionalHeader"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en-us">Specifies the address of the entry point relative to the image base when the executable is loaded into memory.</rdfs:comment>
        <rdfs:label xml:lang="en-us">address_of_entry_point</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#base_of_code -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#base_of_code">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPEOptionalHeader"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en-us">Specifies the address that is relative to the image base of the beginning-of-code section when it is loaded into memory.</rdfs:comment>
        <rdfs:label xml:lang="en-us">base_of_code</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#base_of_data -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#base_of_data">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPEOptionalHeader"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en-us">Specifies the address that is relative to the image base of the beginning-of-data section when it is loaded into memory.</rdfs:comment>
        <rdfs:label xml:lang="en-us">base_of_data</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#characteristics_hex -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#characteristics_hex">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPEBinaryFile"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#hexBinary"/>
        <rdfs:comment xml:lang="en-us">Specifies the flags that indicate the file’s characteristics.</rdfs:comment>
        <rdfs:label xml:lang="en-us">characteristics_hex</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#dll_characteristics_hex -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#dll_characteristics_hex">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPEOptionalHeader"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#hexBinary"/>
        <rdfs:comment xml:lang="en-us">Specifies the flags that characterize the PE binary.</rdfs:comment>
        <rdfs:label xml:lang="en-us">dll_characteristics_hex</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#file_alignment -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#file_alignment">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPEOptionalHeader"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en-us">Specifies the factor (in bytes) that is used to align the raw data of sections in the image file.</rdfs:comment>
        <rdfs:label xml:lang="en-us">file_alignment</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#image_base -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#image_base">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPEOptionalHeader"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en-us">Specifies the preferred address of the first byte of the image when loaded into memory.</rdfs:comment>
        <rdfs:label xml:lang="en-us">image_base</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#imphash -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#imphash">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPEBinaryFile"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies the special import hash, or ‘imphash’, calculated for the PE Binary based on its imported libraries and functions. For more information on the imphash algorithm, see the original article by Mandiant/FireEye [.</rdfs:comment>
        <rdfs:label xml:lang="en-us">imphash</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#loader_flags_hex -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#loader_flags_hex">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPEOptionalHeader"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#hexBinary"/>
        <rdfs:comment xml:lang="en-us">Specifies the reserved loader flags.</rdfs:comment>
        <rdfs:label xml:lang="en-us">loader_flags_hex</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#machine_hex -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#machine_hex">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPEBinaryFile"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#hexBinary"/>
        <rdfs:comment xml:lang="en-us">Specifies the type of target machine.</rdfs:comment>
        <rdfs:label xml:lang="en-us">machine_hex</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#magic_hex -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#magic_hex">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPEOptionalHeader"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#hexBinary"/>
        <rdfs:comment xml:lang="en-us">Specifies the hex value that indicates the type of the PE binary.</rdfs:comment>
        <rdfs:label xml:lang="en-us">magic_hex</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#major_image_version -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#major_image_version">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPEOptionalHeader"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en-us">Specifies the major version number of the image.</rdfs:comment>
        <rdfs:label xml:lang="en-us">major_image_version</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#major_linker_version -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#major_linker_version">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPEOptionalHeader"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en-us">Specifies the linker major version number.</rdfs:comment>
        <rdfs:label xml:lang="en-us">major linker version</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#major_os_version -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#major_os_version">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPEOptionalHeader"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en-us">Specifies the major version number of the required operating system.</rdfs:comment>
        <rdfs:label xml:lang="en-us">major_os_version</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#major_subsystem_version -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#major_subsystem_version">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPEOptionalHeader"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en-us">Specifies the major version number of the subsystem.</rdfs:comment>
        <rdfs:label xml:lang="en-us">major_subsystem_version</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#minor_image_version -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#minor_image_version">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPEOptionalHeader"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en-us">Specifies the minor version number of the image.</rdfs:comment>
        <rdfs:label xml:lang="en-us">minor_image_version</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#minor_linker_version -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#minor_linker_version">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPEOptionalHeader"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en-us">Specifies the linker minor version number.</rdfs:comment>
        <rdfs:label xml:lang="en-us">minor_linker_version</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#minor_os_version -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#minor_os_version">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPEOptionalHeader"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en-us">Specifies the minor version number of the required operating system.</rdfs:comment>
        <rdfs:label xml:lang="en-us">minor_os_version</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#minor_subsystem_version -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#minor_subsystem_version">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPEOptionalHeader"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en-us">Specifies the minor version number of the subsystem.</rdfs:comment>
        <rdfs:label xml:lang="en-us">minor_subsystem_version</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#number_of_rva_and_sizes -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#number_of_rva_and_sizes">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPEOptionalHeader"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en-us">Specifies the number of data-directory entries in the remainder of the optional header.</rdfs:comment>
        <rdfs:label xml:lang="en-us">number_of_rva_and_sizes</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#number_of_sections -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#number_of_sections">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPEBinaryFile"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en-us">Specifies the number of sections in the PE binary, as a non-negative integer.</rdfs:comment>
        <rdfs:label xml:lang="en-us">number_of_sections</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#number_of_symbols -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#number_of_symbols">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPEBinaryFile"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en-us">Specifies the number of entries in the symbol table of the PE binary, as a non-negative integer.</rdfs:comment>
        <rdfs:label xml:lang="en-us">number_of_symbols</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#pe_type -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#pe_type">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPEBinaryFile"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>dll</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>exe</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>sys</rdf:first>
                                        <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <rdfs:comment xml:lang="en-us">Specifies the type of the PE binary. This is an open vocabulary and values SHOULD come from the windows-pebinary-type-ov open vocabulary.</rdfs:comment>
        <rdfs:label xml:lang="en-us">pe_type</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#pointer_to_symbol_table_hex -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#pointer_to_symbol_table_hex">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPEBinaryFile"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#hexBinary"/>
        <rdfs:comment xml:lang="en-us">Specifies the file offset of the COFF symbol table.</rdfs:comment>
        <rdfs:label xml:lang="en-us">pointer_to_symbol_table_hex</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#section_alignment -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#section_alignment">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPEOptionalHeader"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en-us">Specifies the alignment (in bytes) of PE sections when they are loaded into memory.</rdfs:comment>
        <rdfs:label xml:lang="en-us">section_alignment</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#size_of_code -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#size_of_code">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPEOptionalHeader"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en-us">Specifies the size of the code (text) section. If there are multiple such sections, this refers to the sum of the sizes of each section. The value of this property MUST NOT be negative.</rdfs:comment>
        <rdfs:label xml:lang="en-us">size_of_code</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#size_of_headers -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#size_of_headers">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPEOptionalHeader"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en-us">Specifies the combined size of the MS-DOS, PE header, and section headers, rounded up to a multiple of the value specified in the file_alignment header. The value of this property MUST NOT be negative.</rdfs:comment>
        <rdfs:label xml:lang="en-us">size_of_headers</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#size_of_heap_commit -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#size_of_heap_commit">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPEOptionalHeader"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en-us">Specifies the size of the local heap space to commit, in bytes. The value of this property MUST NOT be negative.</rdfs:comment>
        <rdfs:label xml:lang="en-us">size_of_heap_commit</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#size_of_heap_reserve -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#size_of_heap_reserve">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPEOptionalHeader"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en-us">Specifies the size of the local heap space to reserve, in bytes. The value of this property MUST NOT be negative.</rdfs:comment>
        <rdfs:label xml:lang="en-us">size_of_heap_reserve</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#size_of_image -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#size_of_image">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPEOptionalHeader"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en-us">Specifies the size of the image in bytes, including all headers, as the image is loaded in memory. The value of this property MUST NOT be negative.</rdfs:comment>
        <rdfs:label xml:lang="en-us">size_of_image</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#size_of_initialized_data -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#size_of_initialized_data">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPEOptionalHeader"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en-us">Specifies the size of the initialized data section. If there are multiple such sections, this refers to the sum of the sizes of each section. The value of this property MUST NOT be negative.</rdfs:comment>
        <rdfs:label xml:lang="en-us">size_of_initialized_data</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#size_of_optional_header -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#size_of_optional_header">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPEBinaryFile"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en-us">Specifies the size of the optional header of the PE binary. The value of this property MUST NOT be negative.</rdfs:comment>
        <rdfs:label xml:lang="en-us">size_of_optional_header</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#size_of_stack_commit -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#size_of_stack_commit">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPEOptionalHeader"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en-us">Specifies the size of the stack to commit, in bytes. The value of this property MUST NOT be negative.</rdfs:comment>
        <rdfs:label xml:lang="en-us">size_of_stack_commit</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#size_of_stack_reserve -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#size_of_stack_reserve">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPEOptionalHeader"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en-us">Specifies the size of the stack to reserve, in bytes. The value of this property MUST NOT be negative.</rdfs:comment>
        <rdfs:label xml:lang="en-us">size_of_stack_reserve</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#size_of_uninitialized_data -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#size_of_uninitialized_data">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPEOptionalHeader"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en-us">Specifies the size of the uninitialized data section. If there are multiple such sections, this refers to the sum of the sizes of each section. The value of this property MUST NOT be negative.</rdfs:comment>
        <rdfs:label xml:lang="en-us">size of uninitialized data</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#subsystem_hex -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#subsystem_hex">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPEOptionalHeader"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#hexBinary"/>
        <rdfs:comment xml:lang="en-us">Specifies the subsystem (e.g., GUI, device driver, etc.) that is required to run this image.</rdfs:comment>
        <rdfs:label xml:lang="en-us">subsystem_hex</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#time_date_stamp -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#time_date_stamp">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPEBinaryFile"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en-us">Specifies the time when the PE binary was created. The timestamp value MUST be precise to the second.</rdfs:comment>
        <rdfs:label xml:lang="en-us">time_date_stamp</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#win32_version_value_hex -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#win32_version_value_hex">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPEOptionalHeader"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#hexBinary"/>
        <rdfs:comment xml:lang="en-us">Specifies the reserved win32 version value.</rdfs:comment>
        <rdfs:label xml:lang="en-us">win32_version_value_hex</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/file#checksum_hex -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/file#checksum_hex">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPEOptionalHeader"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#hexBinary"/>
        <rdfs:comment xml:lang="en-us">Specifies the checksum of the file.</rdfs:comment>
        <rdfs:label xml:lang="en-us">checksum_hex</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/file#content_ref_id -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/file#content_ref_id">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#File"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies the identifier of an Artifact object that contains the contents of the file.\n\nThe identifier of the object specified in this property MUST be of type artifact.</rdfs:comment>
        <rdfs:label xml:lang="en-us">content_ref_id</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/file#entropy -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/file#entropy">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPESection"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment xml:lang="en-us">Specifies the calculated entropy for the section, as calculated using the Shannon algorithm</rdfs:comment>
        <rdfs:label xml:lang="en-us">entropy</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/file#magic_number_hex -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/file#magic_number_hex">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#File"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#hexBinary"/>
        <rdfs:comment xml:lang="en-us">Specifies the hexadecimal constant associated with a specific file format that corresponds to the file, if applicable.</rdfs:comment>
        <rdfs:label xml:lang="en-us">magic_number_hex</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/file#name_enc -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/file#name_enc">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#File"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies the observed encoding for the name of the file. This value MUST be specified using the corresponding name from the 2013-12-20 revision of the IANA character set registry. If the value from the Preferred MIME Name column for a character set is defined, this value MUST be used; if it is not defined, then the value from the Name column in the registry MUST be used instead.\n\nThis property allows for the capture of the original text encoding for the file name, which may be forensically relevant; for example, a file on an NTFS volume whose name was created using the windows-1251 encoding, commonly used for languages based on Cyrillic script.</rdfs:comment>
        <rdfs:label xml:lang="en-us">name_enc</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/file#parent_directory_ref_id -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/file#parent_directory_ref_id">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#File"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies the identifier of a SCO Directory object that represents the  parent directory of the file.\n\nThe identifier of the object referenced in this property MUST be of type directory.</rdfs:comment>
        <rdfs:label xml:lang="en-us">parent_directory_ref_id</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/file#size -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/file#size">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#File"/>
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/ntfs-file#AlternateDataStream"/>
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix/ext/windows-pebinary-file#WindowsPESection"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en-us">Specifies the size, in bytes. The value of this property MUST NOT be negative.</rdfs:comment>
        <rdfs:label xml:lang="en-us">size</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/grouping#context -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/grouping#context">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#Grouping"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>malware-analysis</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>suspicious-activity</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>unspecified</rdf:first>
                                        <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <rdfs:comment xml:lang="en-us">A short descriptor of the particular context shared by the content referenced by the Grouping.</rdfs:comment>
        <rdfs:label xml:lang="en-us">context</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/identity#contact_information -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/identity#contact_information">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#Identity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">The contact information (e-mail, phone number, etc.) for this Identity. No format for this information is currently defined by this specification.</rdfs:comment>
        <rdfs:label xml:lang="en-us">contact_information</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/identity#identity_class -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/identity#identity_class">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#Identity"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>class</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>group</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>individual</rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                <rdf:first>organization</rdf:first>
                                                <rdf:rest>
                                                    <rdf:Description>
                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                        <rdf:first>system</rdf:first>
                                                        <rdf:rest>
                                                            <rdf:Description>
                                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                <rdf:first>unknown</rdf:first>
                                                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                                            </rdf:Description>
                                                        </rdf:rest>
                                                    </rdf:Description>
                                                </rdf:rest>
                                            </rdf:Description>
                                        </rdf:rest>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <rdfs:comment xml:lang="en-us">The type of entity that this Identity describes, e.g., an individual or organization.\n\nThe value for this property SHOULD come from the identity-class-ov open vocabulary.</rdfs:comment>
        <rdfs:label xml:lang="en-us">identity_class</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/identity#roles -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/identity#roles">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#Identity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">The list of roles that this Identity performs (e.g., CEO, Domain Administrators, Doctors, Hospital, or Retailer). No open vocabulary is yet defined for this property.</rdfs:comment>
        <rdfs:label xml:lang="en-us">roles</rdfs:label>
    </owl:DatatypeProperty>
    


