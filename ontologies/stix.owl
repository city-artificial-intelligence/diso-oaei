        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://docs.oasis-open.org/ns/cti/stix/identity#identity_class"/>
                <owl:hasValue>individual</owl:hasValue>
