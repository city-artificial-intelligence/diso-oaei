            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://docs.oasis-open.org/ns/cti/stix/x509-certificate#subject"/>
