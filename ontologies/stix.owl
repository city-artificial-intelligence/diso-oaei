    <!-- http://docs.oasis-open.org/ns/cti/stix/malware#installed_software_refs_id -->

    <owl:DatatypeProperty rdf:about="http://docs.oasis-open.org/ns/cti/stix/malware#installed_software_refs_id">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#MalwareAnalysis"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en-us">Specifies identifiers of SCO Software objects that represents any non-standard software installed on the operating system (specified through the operating-system value) used for the dynamic analysis of the malware instance or family.\n\nThe value of this property MUST be identifiers of SCO software objects.</rdfs:comment>
        <rdfs:label xml:lang="en-us">installed_software_refs_id</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://docs.oasis-open.org/ns/cti/stix/malware#is_family -->

