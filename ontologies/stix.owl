        <rdfs:domain rdf:resource="http://docs.oasis-open.org/ns/cti/stix#Malware"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en-us">Specifies whether the object represents a malware family (if true) or a malware instance (if false).</rdfs:comment>
        <rdfs:label xml:lang="en-us">is_family</rdfs:label>
    </owl:DatatypeProperty>
    


