            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en-us">The URL object represents the properties of a uniform resource locator (URL).</rdfs:comment>
        <rdfs:label xml:lang="en-us">URL</rdfs:label>
    </owl:Class>
    


