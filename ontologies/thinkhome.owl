                        </owl:withRestrictions>
                    </rdfs:Datatype>
                </owl:onDataRange>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">atmospheric pressure in hectopascal (hPa)</rdfs:comment>
    </owl:Class>
    


