        <rdfs:comment xml:lang="en">length of, or element of the length of, a temporal extent expressed in years</rdfs:comment>
        <rdfs:label xml:lang="es">duración en años</rdfs:label>
        <rdfs:label xml:lang="en">years duration</rdfs:label>
    </owl:DatatypeProperty>
    


