                        <owl:onClass rdf:resource="https://www.auto.tuwien.ac.at/downloads/thinkhome/ontology/EnergyResourceOntology.owl#TemperatureState"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
