        <rdfs:comment xml:lang="en">the user preference profile class represents consolidated human actor preferences per user</rdfs:comment>
        <rdfs:comment xml:lang="en">this class was known as &quot;UserPreferenceProfile&quot; in prior versions of the ontology</rdfs:comment>
    </owl:Class>
    


    <!-- https://www.auto.tuwien.ac.at/downloads/thinkhome/ontology/ActorOntology.owl#LevelOfSatisfaction -->

