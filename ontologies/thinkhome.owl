    <owl:NamedIndividual rdf:about="http://www.w3.org/2006/time#unitMonth">
        <rdf:type rdf:resource="http://www.w3.org/2006/time#TemporalUnit"/>
        <time:days rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</time:days>
