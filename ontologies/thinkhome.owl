                        <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment>Properties of one layer of a window</rdfs:comment>
    </owl:Class>
    


