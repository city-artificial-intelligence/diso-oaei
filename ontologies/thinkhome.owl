                <owl:someValuesFrom rdf:resource="http://www.w3.org/2006/time#Interval"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">patterns represent repeating user behaviour. a pattern generator uses profiles to generate patterns.</rdfs:comment>
    </owl:Class>
    


    <!-- https://www.auto.tuwien.ac.at/downloads/thinkhome/ontology/ProcessOntology.owl#Presence -->

    <owl:Class rdf:about="https://www.auto.tuwien.ac.at/downloads/thinkhome/ontology/ProcessOntology.owl#Presence">
        <owl:equivalentClass>
