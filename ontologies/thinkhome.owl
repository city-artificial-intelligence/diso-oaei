                                                <owl:onProperty rdf:resource="http://www.w3.org/2006/time#month"/>
                                                <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#gMonth">--05</owl:hasValue>
                                            </owl:Restriction>
                                        </owl:unionOf>
                                    </owl:Class>
                                </owl:someValuesFrom>
                            </owl:Restriction>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>
    


