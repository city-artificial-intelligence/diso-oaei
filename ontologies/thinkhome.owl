        <rdfs:range rdf:resource="https://www.auto.tuwien.ac.at/downloads/thinkhome/ontology/EnergyResourceOntology.owl#BuildingThing"/>
        <rdfs:comment xml:lang="en">Association between an object and its controller,e.g.switch,button,knob</rdfs:comment>
        <rdfs:label>hasControl</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://www.auto.tuwien.ac.at/downloads/thinkhome/ontology/EnergyResourceOntology.owl#hasCurrentStateValue -->

