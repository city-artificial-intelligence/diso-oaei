    <!-- https://www.auto.tuwien.ac.at/downloads/thinkhome/ontology/BuildingOntology.owl#hasWallASHRAEGroupValue -->

    <owl:DatatypeProperty rdf:about="https://www.auto.tuwien.ac.at/downloads/thinkhome/ontology/BuildingOntology.owl#hasWallASHRAEGroupValue">
