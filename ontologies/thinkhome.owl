    </owl:DatatypeProperty>
    


    <!-- https://www.auto.tuwien.ac.at/downloads/thinkhome/ontology/ProcessOntology.owl#hasMaxValue -->

    <owl:DatatypeProperty rdf:about="https://www.auto.tuwien.ac.at/downloads/thinkhome/ontology/ProcessOntology.owl#hasMaxValue">
        <rdfs:subPropertyOf rdf:resource="https://www.auto.tuwien.ac.at/downloads/thinkhome/ontology/ProcessOntology.owl#hasValue"/>
        <rdfs:comment xml:lang="en">has been created to define the maximum allowed profile range value</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- https://www.auto.tuwien.ac.at/downloads/thinkhome/ontology/ProcessOntology.owl#hasMinValue -->

    <owl:DatatypeProperty rdf:about="https://www.auto.tuwien.ac.at/downloads/thinkhome/ontology/ProcessOntology.owl#hasMinValue">
