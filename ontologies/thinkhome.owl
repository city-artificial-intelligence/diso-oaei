            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.auto.tuwien.ac.at/downloads/thinkhome/ontology/ProcessOntology.owl#Pattern"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.auto.tuwien.ac.at/downloads/thinkhome/ontology/ProcessOntology.owl#validFor"/>
                        <owl:someValuesFrom>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://www.w3.org/2006/time#hasDateTimeDescription"/>
                                <owl:someValuesFrom>
                                    <owl:Class>
                                        <owl:unionOf rdf:parseType="Collection">
                                            <owl:Restriction>
                                                <owl:onProperty rdf:resource="http://www.w3.org/2006/time#month"/>
                                                <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#gMonth">--03</owl:hasValue>
                                            </owl:Restriction>
                                            <owl:Restriction>
                                                <owl:onProperty rdf:resource="http://www.w3.org/2006/time#month"/>
                                                <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#gMonth">--04</owl:hasValue>
                                            </owl:Restriction>
