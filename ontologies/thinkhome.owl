                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.auto.tuwien.ac.at/downloads/thinkhome/ontology/ActorOntology.owl#hasPreferenceProfile"/>
                        <owl:someValuesFrom rdf:resource="https://www.auto.tuwien.ac.at/downloads/thinkhome/ontology/ActorOntology.owl#HumanActorPreferenceProfile"/>
                    </owl:Restriction>
