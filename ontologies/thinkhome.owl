                        <owl:someValuesFrom rdf:resource="https://www.auto.tuwien.ac.at/downloads/thinkhome/ontology/EnergyResourceOntology.owl#OnOffFunctionality"/>
                    </owl:Restriction>
                    <owl:Restriction>
