                        <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment>List of year schedules that make up an entire calendar year.</rdfs:comment>
    </owl:Class>
    


