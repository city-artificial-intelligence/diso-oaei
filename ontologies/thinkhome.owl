    <!-- https://www.auto.tuwien.ac.at/downloads/thinkhome/ontology/EnergyResourceOntology.owl#actuallyConsumesEnergy -->

    <owl:ObjectProperty rdf:about="https://www.auto.tuwien.ac.at/downloads/thinkhome/ontology/EnergyResourceOntology.owl#actuallyConsumesEnergy">
        <rdfs:subPropertyOf rdf:resource="https://www.auto.tuwien.ac.at/downloads/thinkhome/ontology/EnergyResourceOntology.owl#consumesEnergy"/>
        <owl:inverseOf rdf:resource="https://www.auto.tuwien.ac.at/downloads/thinkhome/ontology/EnergyResourceOntology.owl#energyActuallyConsumedBy"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://www.auto.tuwien.ac.at/downloads/thinkhome/ontology/EnergyResourceOntology.owl#hasCurrentStateValue"/>
            <rdf:Description rdf:about="https://www.auto.tuwien.ac.at/downloads/thinkhome/ontology/EnergyResourceOntology.owl#hasEnergyDemand"/>
        </owl:propertyChainAxiom>
        <rdfs:comment xml:lang="en">how much energy is consumed by an energy facility at a certain point in time</rdfs:comment>
        <rdfs:comment xml:lang="en">this property was known as &quot;currentlyConsumesEnergy&quot; in prior versions of the ontology</rdfs:comment>
        <rdfs:label>actuallyConsumesEnergy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://www.auto.tuwien.ac.at/downloads/thinkhome/ontology/EnergyResourceOntology.owl#actuallyProducesEnergy -->

    <owl:ObjectProperty rdf:about="https://www.auto.tuwien.ac.at/downloads/thinkhome/ontology/EnergyResourceOntology.owl#actuallyProducesEnergy">
        <rdfs:subPropertyOf rdf:resource="https://www.auto.tuwien.ac.at/downloads/thinkhome/ontology/EnergyResourceOntology.owl#producesEnergy"/>
        <owl:inverseOf rdf:resource="https://www.auto.tuwien.ac.at/downloads/thinkhome/ontology/EnergyResourceOntology.owl#energyActuallyProducedBy"/>
        <rdfs:comment xml:lang="en">The amount of energy a facility produces at a certain point in time</rdfs:comment>
        <rdfs:label>actuallyProducesEnergy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://www.auto.tuwien.ac.at/downloads/thinkhome/ontology/EnergyResourceOntology.owl#actuatorOf -->

