        <rdfs:label xml:lang="es">hora</rdfs:label>
        <rdfs:label xml:lang="en">hour</rdfs:label>
        <skos:definition xml:lang="en">Hour position in a calendar-clock system.</skos:definition>
        <skos:definition xml:lang="es">Posición de hora en un sistema calendario-reloj.</skos:definition>
    </owl:DatatypeProperty>
    


