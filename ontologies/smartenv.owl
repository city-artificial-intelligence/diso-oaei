        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.1/req/geometry-extension/spatial-object-properties"/>
        <skos:definition xml:lang="en">The volume of a three-dimensional Spatial Object.</skos:definition>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#C.1.2.2"/>
        <skos:prefLabel xml:lang="en">has volume</skos:prefLabel>
    </owl:ObjectProperty>
    


