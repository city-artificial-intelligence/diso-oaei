    <!-- http://www.cenitmio.es/ontologies/Device.owl#CO2LevelSensor -->

    <owl:Class rdf:about="http://www.cenitmio.es/ontologies/Device.owl#CO2LevelSensor">
        <rdfs:subClassOf rdf:resource="http://www.cenitmio.es/ontologies/Device.owl#Sensor"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/Device.owl#hasChargingMode"/>
                        <owl:someValuesFrom rdf:resource="http://www.cenitmio.es/ontologies/Device.owl#ChargingMode"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/mIO.owl#hasInterfaceWithModality"/>
                        <owl:someValuesFrom rdf:resource="http://www.cenitmio.es/ontologies/mIO.owl#NAryRelationHasInterfaceWithModality"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/componency.owl#hasComponent"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:unionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#Amplifier"/>
                                    <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#Detector"/>
                                    <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#SensorSource"/>
                                </owl:unionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/mIO.owl#isDeviceIncludedIn"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Location.owl#PublicProperty"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Location.owl#PublicTransport"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/Device.owl#isConnectedWithDevice"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#DeviceEmbeddedInPublicTransport"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#UrbanInfrastructureDevice"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Un sensor de nivel de CO2 proporciona como dato un valor de tensión proporcional al nivel de dióxido de carbono gaseoso detectado.</rdfs:comment>
        <rdfs:label>CO2LevelSensor</rdfs:label>
    </owl:Class>
    


