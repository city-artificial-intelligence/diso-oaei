    <!-- http://www.cenitmio.es/ontologies/Device.owl#Printer -->

    <owl:Class rdf:about="http://www.cenitmio.es/ontologies/Device.owl#Printer">
        <owl:equivalentClass rdf:resource="http://www.cenitmio.es/ontologies/Device.owl#PrinterByPrintingTechnology"/>
        <owl:equivalentClass rdf:resource="http://www.cenitmio.es/ontologies/Device.owl#PrinterByPrintinghCharacteristic"/>
        <rdfs:subClassOf rdf:resource="http://www.cenitmio.es/ontologies/Device.owl#Device"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/mIO.owl#hasInterfaceWithModality"/>
                        <owl:someValuesFrom rdf:resource="http://www.cenitmio.es/ontologies/mIO.owl#NAryRelationHasInterfaceWithModality"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/componency.owl#hasComponent"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:unionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#Display"/>
                                    <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#InkContainer"/>
                                    <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#MemoryModule"/>
                                    <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#PaperTray"/>
                                    <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#Printhead"/>
                                    <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#ProcessingModule"/>
                                </owl:unionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/Device.owl#isCompatibleWithStandard"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:oneOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#pictbridge"/>
                        </owl:oneOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/Device.owl#isConnectedWithDevice"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#Camera"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#Display"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#LargeDistanceCommunicationModule"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#MemoryModule"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#ProcessingModule"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#ReadingWritingModuleNFC"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#ShortDistanceCommunicationModule"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#TouchScreen"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/mIO.owl#hasConnectionInterface"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Interface.owl#BluetoothConnectionInterface"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Interface.owl#ParallelPortConnectionInterface"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Interface.owl#SerialPortConnectionInterface"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Interface.owl#USBConnectionInterface"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Interface.owl#WiFiConnectionInterface"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Una impresora proporciona un servicio de impresión.</rdfs:comment>
        <rdfs:label>Printer</rdfs:label>
    </owl:Class>
    


