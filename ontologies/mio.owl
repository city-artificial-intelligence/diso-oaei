    <!-- http://www.cenitmio.es/ontologies/Location.owl#PostalDistrict -->

    <owl:Class rdf:about="http://www.cenitmio.es/ontologies/Location.owl#PostalDistrict">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://pervasive.semanticweb.org/ont/2004/06/space#GeopoliticalEntity"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/Location.owl#isPartOfGeoDirect"/>
                        <owl:someValuesFrom rdf:resource="http://www.cenitmio.es/ontologies/Location.owl#City"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/Location.owl#isPartOfGeoDirect"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.cenitmio.es/ontologies/Location.owl#City"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://www.cenitmio.es/ontologies/Location.owl#Province"/>
        <rdfs:comment>Un distrito postal es un objeto geopolítico que forma parte de una y sólo una ciudad.</rdfs:comment>
        <rdfs:label xml:lang="es">Distrito postal</rdfs:label>
        <rdfs:label xml:lang="en">Postal district</rdfs:label>
    </owl:Class>
    


    <!-- http://www.cenitmio.es/ontologies/Location.owl#Province -->

    <owl:Class rdf:about="http://www.cenitmio.es/ontologies/Location.owl#Province">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://pervasive.semanticweb.org/ont/2004/06/space#GeopoliticalEntity"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/Location.owl#hasGeoDirect"/>
                        <owl:someValuesFrom rdf:resource="http://www.cenitmio.es/ontologies/Location.owl#City"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/Location.owl#isPartOfGeoDirect"/>
                        <owl:someValuesFrom rdf:resource="http://www.cenitmio.es/ontologies/Location.owl#AutonomousRegion"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/Location.owl#isPartOfGeoDirect"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.cenitmio.es/ontologies/Location.owl#AutonomousRegion"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Una provincia es un objeto geopolítico que tiene una o más ciudades y es parte de una y sólo una comunidad autónoma.</rdfs:comment>
        <rdfs:label xml:lang="en">Province</rdfs:label>
        <rdfs:label xml:lang="es">Provincia</rdfs:label>
    </owl:Class>
    


