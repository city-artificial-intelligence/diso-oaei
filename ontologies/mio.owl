    <!-- http://www.cenitmio.es/ontologies/Device.owl#TouchScreen -->

    <owl:Class rdf:about="http://www.cenitmio.es/ontologies/Device.owl#TouchScreen">
        <rdfs:subClassOf rdf:resource="http://www.cenitmio.es/ontologies/Device.owl#Device"/>
        <rdfs:subClassOf rdf:resource="http://www.cenitmio.es/ontologies/Interface.owl#TouchInterface"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/mIO.owl#isDeviceIncludedIn"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#ComputerTerminal"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#NavigationSystem"/>
