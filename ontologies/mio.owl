        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://sweet.jpl.nasa.gov/ontology/units.owl#hasValue"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>Prefix</rdfs:label>
    </owl:Class>
    


