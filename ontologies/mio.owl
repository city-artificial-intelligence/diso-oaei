    <!-- http://www.cenitmio.es/ontologies/Device.owl#Loudspeaker -->

    <owl:Class rdf:about="http://www.cenitmio.es/ontologies/Device.owl#Loudspeaker">
        <owl:equivalentClass rdf:resource="http://www.cenitmio.es/ontologies/Device.owl#LoudspeakerByDirectivity"/>
        <rdfs:subClassOf rdf:resource="http://www.cenitmio.es/ontologies/Device.owl#Device"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/mIO.owl#hasInterfaceWithModality"/>
                        <owl:someValuesFrom rdf:resource="http://www.cenitmio.es/ontologies/mIO.owl#NAryRelationHasInterfaceWithModality"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/componency.owl#hasComponent"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:unionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#ActiveComponent"/>
                                    <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#Amplifier"/>
                                    <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#Casing"/>
                                    <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#Decoder"/>
                                    <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#SignalProcessor"/>
                                </owl:unionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/Device.owl#isASharedDeviceForInput"/>
                        <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</owl:hasValue>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/Device.owl#isASharedDeviceForOutput"/>
                        <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:hasValue>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/Device.owl#isConnectedWithDevice"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#Camera"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#Decoder"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#GPSReceiver"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#LargeDistanceCommunicationModule"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#MemoryModule"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#Microphone"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#ProcessingModule"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#ShortDistanceCommunicationModule"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/mIO.owl#hasConnectionInterface"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Interface.owl#AES3ConnectionInterface"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Interface.owl#AnalogMultichannelConnectionInterface"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Interface.owl#BasicConnectionInterface"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Interface.owl#BluetoothConnectionInterface"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Interface.owl#RCAConnectionInterface"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Interface.owl#SPDIFConnectionInterface"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Interface.owl#ToslinkConnectionInterface"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Interface.owl#WirelessConnectionInterface"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Un altavoz genera sonido a partir de una señal eléctrica recibida.</rdfs:comment>
        <rdfs:label>Loudspeaker</rdfs:label>
    </owl:Class>
    


