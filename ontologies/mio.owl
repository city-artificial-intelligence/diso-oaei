    <!-- http://www.cenitmio.es/ontologies/Provider.owl#ServiceProvider -->

    <owl:Class rdf:about="http://www.cenitmio.es/ontologies/Provider.owl#ServiceProvider">
        <owl:equivalentClass rdf:resource="http://www.cenitmio.es/ontologies/Provider.owl#ServiceProviderByCardinality"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#Device"/>
                            <rdf:Description rdf:about="http://xmlns.com/foaf/0.1/Person"/>
                            <rdf:Description rdf:about="http://xmlns.com/wordnet/1.6/Organization"/>
                        </owl:unionOf>
                    </owl:Class>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/mIO.owl#offersServiceAtPlaceInTimeWithPrice"/>
                        <owl:someValuesFrom rdf:resource="http://www.cenitmio.es/ontologies/mIO.owl#NAryRelationOffersServiceAtPlaceInTimeWithPrice"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="es">Proveedor de servicio</rdfs:label>
        <rdfs:label xml:lang="en">Service provider</rdfs:label>
    </owl:Class>
    


