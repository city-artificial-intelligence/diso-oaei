    <!-- http://sweet.jpl.nasa.gov/ontology/units.owl#Prefix -->

    <owl:Class rdf:about="http://sweet.jpl.nasa.gov/ontology/units.owl#Prefix">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://sweet.jpl.nasa.gov/ontology/units.owl#hasSymbol"/>
