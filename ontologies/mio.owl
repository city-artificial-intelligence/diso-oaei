        <rdfs:label xml:lang="en">inputMessage</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.cenitmio.es/ontologies/service.owl#isReceivedBy -->

    <owl:ObjectProperty rdf:about="http://www.cenitmio.es/ontologies/service.owl#isReceivedBy">
