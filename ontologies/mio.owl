                    <rdf:Description rdf:about="http://xmlns.com/foaf/0.1/Agent"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Esta propiedad relaciona un mensaje con la entidad que lo recibe.</rdfs:comment>
        <rdfs:label xml:lang="en">isReceivedBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.cenitmio.es/ontologies/service.owl#isSentBy -->

    <owl:ObjectProperty rdf:about="http://www.cenitmio.es/ontologies/service.owl#isSentBy">
        <owl:inverseOf rdf:resource="http://www.cenitmio.es/ontologies/service.owl#sends"/>
        <rdfs:domain rdf:resource="http://www.cenitmio.es/ontologies/service.owl#Message"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/service.owl#Service"/>
                    <rdf:Description rdf:about="http://xmlns.com/foaf/0.1/Agent"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Esta propiedad relaciona un mensaje con la entidad que lo envía.</rdfs:comment>
        <rdfs:label xml:lang="en"></rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.cenitmio.es/ontologies/service.owl#messageData -->

    <owl:ObjectProperty rdf:about="http://www.cenitmio.es/ontologies/service.owl#messageData">
        <rdfs:domain rdf:resource="http://www.cenitmio.es/ontologies/service.owl#Message"/>
        <rdfs:comment xml:lang="en">Describe el contenido del mensaje</rdfs:comment>
        <rdfs:label xml:lang="en">messageData</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.cenitmio.es/ontologies/service.owl#outputMessage -->

    <owl:ObjectProperty rdf:about="http://www.cenitmio.es/ontologies/service.owl#outputMessage">
        <rdfs:domain rdf:resource="http://www.cenitmio.es/ontologies/service.owl#Message"/>
        <rdfs:range rdf:resource="http://www.cenitmio.es/ontologies/service.owl#Operation"/>
        <rdfs:comment xml:lang="en">Esta propiedad relaciona un mensaje con la operación del servicio correspondiente (output).</rdfs:comment>
        <rdfs:label xml:lang="en">outputMessage</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.cenitmio.es/ontologies/service.owl#postcondition -->

    <owl:ObjectProperty rdf:about="http://www.cenitmio.es/ontologies/service.owl#postcondition">
        <rdfs:domain rdf:resource="http://www.cenitmio.es/ontologies/service.owl#Operation"/>
        <rdfs:comment xml:lang="en">Define el tipo de respuesta (output) que genera la operación de un servicio.</rdfs:comment>
        <rdfs:label xml:lang="en">postcondition</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.cenitmio.es/ontologies/service.owl#precondition -->

    <owl:ObjectProperty rdf:about="http://www.cenitmio.es/ontologies/service.owl#precondition">
        <rdfs:domain rdf:resource="http://www.cenitmio.es/ontologies/service.owl#Operation"/>
        <rdfs:comment xml:lang="en">Define el tipo de entrada (input) que requiere la operación de un servicio.</rdfs:comment>
        <rdfs:label xml:lang="en">precondition</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.cenitmio.es/ontologies/service.owl#receives -->

    <owl:ObjectProperty rdf:about="http://www.cenitmio.es/ontologies/service.owl#receives">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/service.owl#Service"/>
                    <rdf:Description rdf:about="http://xmlns.com/foaf/0.1/Agent"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.cenitmio.es/ontologies/service.owl#Message"/>
        <rdfs:comment xml:lang="en">Los servicios y agentes reciben mensajes durante la comunicación con otra entidad.</rdfs:comment>
        <rdfs:label xml:lang="en">receives</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.cenitmio.es/ontologies/service.owl#sends -->

    <owl:ObjectProperty rdf:about="http://www.cenitmio.es/ontologies/service.owl#sends">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/service.owl#Service"/>
                    <rdf:Description rdf:about="http://xmlns.com/foaf/0.1/Agent"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.cenitmio.es/ontologies/service.owl#Message"/>
        <rdfs:comment xml:lang="en">Los servicios y agentes envían mensajes durante la comunicación con otra entidad.</rdfs:comment>
        <rdfs:label xml:lang="en">sends</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontologydesignpatterns.org/cp/owl/componency.owl#hasComponent -->

    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/cp/owl/componency.owl#hasComponent">
        <rdfs:subPropertyOf rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/partof.owl#hasPart"/>
        <owl:inverseOf rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/componency.owl#isComponentOf"/>
        <rdfs:domain rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/componency.owl#Object"/>
        <rdfs:range rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/componency.owl#Object"/>
        <rdfs:comment>The hasPart relation without transitivity, holding between an Object (the system) and another (the component), and assuming a Design that structures the system Object. For an explicit pattern encoding Design, see the &apos;designobject&apos; pattern.
The componency pattern uses the transitive reduction logical pattern to preserve transitive on the superproperty from the partof pattern. In practice, the partof pattern acts here as the transitive reduction of the componency pattern.</rdfs:comment>
        <rdfs:label xml:lang="en">has component</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontologydesignpatterns.org/cp/owl/componency.owl#isComponentOf -->

    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/cp/owl/componency.owl#isComponentOf">
        <rdfs:subPropertyOf rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/partof.owl#isPartOf"/>
        <rdfs:domain rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/componency.owl#Object"/>
        <rdfs:range rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/componency.owl#Object"/>
        <rdfs:label xml:lang="en">is component of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontologydesignpatterns.org/cp/owl/partof.owl#hasPart -->

    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/cp/owl/partof.owl#hasPart">
        <owl:inverseOf rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/partof.owl#isPartOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment>A transitive relation expressing parthood between any entities, e.g. &apos;the human body has a brain as part&apos;. When specializing this pattern, take care of restricting the domain and range appropriately, since it could be counterintuitive to use this relation arbitrarily, e.g. between animals and planets. For an intransitive partof pattern, see &apos;componency&apos;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/partof.owl"/>
        <rdfs:label xml:lang="en">has part</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontologydesignpatterns.org/cp/owl/partof.owl#isPartOf -->

    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/cp/owl/partof.owl#isPartOf">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment>A transitive relation expressing parthood between any entities, e.g. &apos;brain is a part of the human body&apos;. When specializing this pattern, take care of restricting the domain and range appropriately, since it could be counterintuitive to use this relation arbitrarily, e.g. between animals and planets. For an intransitive partof pattern, see &apos;componency&apos;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/partof.owl"/>
        <rdfs:label xml:lang="en">is part of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontologydesignpatterns.org/cp/owl/price.owl#hasCurrency -->

    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/cp/owl/price.owl#hasCurrency">
        <rdfs:domain rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/price.owl#Price"/>
        <rdfs:range rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/price.owl#Currency"/>
        <rdfs:label xml:lang="en">has currency</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontologydesignpatterns.org/cp/owl/price.owl#hasPrice -->

    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/cp/owl/price.owl#hasPrice">
        <owl:inverseOf rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/price.owl#isPriceOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/price.owl#Price"/>
        <rdfs:label xml:lang="en">has price</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.ontologydesignpatterns.org/cp/owl/price.owl#isPriceOf -->

    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/cp/owl/price.owl#isPriceOf">
        <rdfs:domain rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/price.owl#Price"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:label xml:lang="en">is price of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#after -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#after">
        <owl:inverseOf rdf:resource="http://www.w3.org/2006/time#before"/>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#before -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#before">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2006/time#TemporalEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#TemporalEntity"/>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#dayOfWeek -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#dayOfWeek">
        <rdfs:domain rdf:resource="http://www.w3.org/2006/time#DateTimeDescription"/>
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#DayOfWeek"/>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#hasBeginning -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#hasBeginning">
        <rdfs:domain rdf:resource="http://www.w3.org/2006/time#TemporalEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#Instant"/>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#hasDateTimeDescription -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#hasDateTimeDescription">
        <rdfs:domain rdf:resource="http://www.w3.org/2006/time#DateTimeInterval"/>
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#DateTimeDescription"/>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#hasDurationDescription -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#hasDurationDescription">
        <rdfs:domain rdf:resource="http://www.w3.org/2006/time#TemporalEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#DurationDescription"/>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#hasEnd -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#hasEnd">
        <rdfs:domain rdf:resource="http://www.w3.org/2006/time#TemporalEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#Instant"/>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#inDateTime -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#inDateTime">
        <rdfs:domain rdf:resource="http://www.w3.org/2006/time#Instant"/>
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#DateTimeDescription"/>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#inside -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#inside">
        <rdfs:domain rdf:resource="http://www.w3.org/2006/time#Interval"/>
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#Instant"/>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#intervalAfter -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#intervalAfter">
        <owl:inverseOf rdf:resource="http://www.w3.org/2006/time#intervalBefore"/>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#intervalBefore -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#intervalBefore">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2006/time#before"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2006/time#ProperInterval"/>
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#ProperInterval"/>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#intervalContains -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#intervalContains">
        <owl:inverseOf rdf:resource="http://www.w3.org/2006/time#intervalDuring"/>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#intervalDuring -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#intervalDuring">
