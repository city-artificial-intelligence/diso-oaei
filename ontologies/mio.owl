    <!-- http://www.cenitmio.es/ontologies/mIO.owl#Prosumer -->

    <owl:Class rdf:about="http://www.cenitmio.es/ontologies/mIO.owl#Prosumer">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/mIO.owl#executes"/>
                                <owl:someValuesFrom rdf:resource="http://www.cenitmio.es/ontologies/Service.owl#Service"/>
                            </owl:Restriction>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/mIO.owl#requests"/>
                                <owl:someValuesFrom rdf:resource="http://www.cenitmio.es/ontologies/Service.owl#Service"/>
                            </owl:Restriction>
                        </owl:unionOf>
                    </owl:Class>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/mIO.owl#offersServiceAtPlaceInTimeWithPrice"/>
                                <owl:someValuesFrom rdf:resource="http://www.cenitmio.es/ontologies/mIO.owl#NAryRelationOffersServiceAtPlaceInTimeWithPrice"/>
                            </owl:Restriction>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/mIO.owl#providesService"/>
                                <owl:someValuesFrom rdf:resource="http://www.cenitmio.es/ontologies/Service.owl#MIOService"/>
                            </owl:Restriction>
                        </owl:unionOf>
                    </owl:Class>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Provider.owl#ServiceProvider"/>
                    <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/User.owl#User"/>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:label>Prosumer</rdfs:label>
    </owl:Class>
    


    <!-- http://www.cenitmio.es/ontologies/mIO.owl#URLLinkInformation -->

    <owl:Class rdf:about="http://www.cenitmio.es/ontologies/mIO.owl#URLLinkInformation">
        <rdfs:subClassOf rdf:resource="http://www.cenitmio.es/ontologies/mIO.owl#Information"/>
        <rdfs:label xml:lang="en">URLLinkInformation</rdfs:label>
        <rdfs:label xml:lang="es">información de un enlace a una URL</rdfs:label>
    </owl:Class>
    


    <!-- http://www.cenitmio.es/ontologies/service.owl#Message -->

    <owl:Class rdf:about="http://www.cenitmio.es/ontologies/service.owl#Message">
        <rdfs:comment xml:lang="en">Un mensaje es la información o el conjunto de datos que se envían desde un emisor a un receptor.</rdfs:comment>
        <rdfs:label xml:lang="en">Message</rdfs:label>
    </owl:Class>
    


    <!-- http://www.cenitmio.es/ontologies/service.owl#Operation -->

    <owl:Class rdf:about="http://www.cenitmio.es/ontologies/service.owl#Operation">
        <rdfs:comment xml:lang="en">Una operación es una acción o procedimiento que produce un nuevo valor a partir de un conjunto de datos de entrada.</rdfs:comment>
        <rdfs:label xml:lang="en">Operation</rdfs:label>
    </owl:Class>
    


    <!-- http://www.cenitmio.es/ontologies/service.owl#Service -->

    <owl:Class rdf:about="http://www.cenitmio.es/ontologies/service.owl#Service">
        <rdfs:comment xml:lang="en">Un servicio web es un sistema de software diseñado para permitir la interacción interoperable entre máquinas (aplicaciones) sobre una red (W3C).</rdfs:comment>
        <rdfs:label xml:lang="en">Service</rdfs:label>
    </owl:Class>
    


    <!-- http://www.ontologydesignpatterns.org/cp/owl/componency.owl#Object -->

    <owl:Class rdf:about="http://www.ontologydesignpatterns.org/cp/owl/componency.owl#Object">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/componency.owl#hasComponent"/>
                <owl:allValuesFrom rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/componency.owl#Object"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/componency.owl#isComponentOf"/>
                <owl:allValuesFrom rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/componency.owl#Object"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Any physical, social, or mental object, or a substance</rdfs:comment>
        <rdfs:label xml:lang="en">Object</rdfs:label>
    </owl:Class>
    


    <!-- http://www.ontologydesignpatterns.org/cp/owl/price.owl#Currency -->

    <owl:Class rdf:about="http://www.ontologydesignpatterns.org/cp/owl/price.owl#Currency">
        <owl:disjointWith rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/price.owl#Price"/>
        <rdfs:comment>A system of money in general use in a particular country.</rdfs:comment>
        <rdfs:label xml:lang="en">Currency</rdfs:label>
    </owl:Class>
    


    <!-- http://www.ontologydesignpatterns.org/cp/owl/price.owl#Price -->

    <owl:Class rdf:about="http://www.ontologydesignpatterns.org/cp/owl/price.owl#Price">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/price.owl#hasCurrency"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/price.owl#hasValue"/>
                <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>The amount of money expected, required, or given in payment for something.</rdfs:comment>
        <rdfs:label xml:lang="en">Price</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/2000/10/swap/pim/contact#Person -->

    <owl:Class rdf:about="http://www.w3.org/2000/10/swap/pim/contact#Person">
        <rdfs:label>Person</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/2002/07/owl#Thing -->

    <owl:Class rdf:about="http://www.w3.org/2002/07/owl#Thing">
        <rdfs:label>Thing</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/2003/01/geo/wgs84_pos#SpatialThing -->

    <owl:Class rdf:about="http://www.w3.org/2003/01/geo/wgs84_pos#SpatialThing">
        <rdfs:label>SpatialThing</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/2006/time#DateTimeDescription -->

    <owl:Class rdf:about="http://www.w3.org/2006/time#DateTimeDescription">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2006/time#unitType"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2006/time#dayOfWeek"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2006/time#timeZone"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2006/time#day"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2006/time#dayOfYear"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2006/time#hour"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2006/time#minute"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2006/time#month"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2006/time#second"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2006/time#week"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2006/time#year"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>DateTimeDescription</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/2006/time#DateTimeInterval -->

    <owl:Class rdf:about="http://www.w3.org/2006/time#DateTimeInterval">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2006/time#ProperInterval"/>
        <rdfs:label>DateTimeInterval</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/2006/time#DayOfWeek -->

    <owl:Class rdf:about="http://www.w3.org/2006/time#DayOfWeek">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2006/time#Friday"/>
                    <rdf:Description rdf:about="http://www.w3.org/2006/time#Monday"/>
                    <rdf:Description rdf:about="http://www.w3.org/2006/time#Saturday"/>
                    <rdf:Description rdf:about="http://www.w3.org/2006/time#Sunday"/>
                    <rdf:Description rdf:about="http://www.w3.org/2006/time#Thursday"/>
                    <rdf:Description rdf:about="http://www.w3.org/2006/time#Tuesday"/>
                    <rdf:Description rdf:about="http://www.w3.org/2006/time#Wednesday"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:label>DayOfWeek</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/2006/time#DurationDescription -->

    <owl:Class rdf:about="http://www.w3.org/2006/time#DurationDescription">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2006/time#days"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2006/time#hours"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2006/time#minutes"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2006/time#months"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2006/time#seconds"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2006/time#weeks"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2006/time#years"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>DurationDescription</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/2006/time#Instant -->

    <owl:Class rdf:about="http://www.w3.org/2006/time#Instant">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2006/time#TemporalEntity"/>
        <owl:disjointWith rdf:resource="http://www.w3.org/2006/time#ProperInterval"/>
        <rdfs:label>Instant</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/2006/time#Interval -->

    <owl:Class rdf:about="http://www.w3.org/2006/time#Interval">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2006/time#TemporalEntity"/>
        <rdfs:label>Interval</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/2006/time#ProperInterval -->

    <owl:Class rdf:about="http://www.w3.org/2006/time#ProperInterval">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2006/time#Interval"/>
        <rdfs:label>ProperInterval</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/2006/time#TemporalEntity -->

    <owl:Class rdf:about="http://www.w3.org/2006/time#TemporalEntity">
        <owl:equivalentClass>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2006/time#Instant"/>
                    <rdf:Description rdf:about="http://www.w3.org/2006/time#Interval"/>
                </owl:unionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:label>TemporalEntity</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/2006/time#TemporalUnit -->

    <owl:Class rdf:about="http://www.w3.org/2006/time#TemporalUnit">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2006/time#unitDay"/>
                    <rdf:Description rdf:about="http://www.w3.org/2006/time#unitHour"/>
                    <rdf:Description rdf:about="http://www.w3.org/2006/time#unitMinute"/>
                    <rdf:Description rdf:about="http://www.w3.org/2006/time#unitMonth"/>
                    <rdf:Description rdf:about="http://www.w3.org/2006/time#unitSecond"/>
                    <rdf:Description rdf:about="http://www.w3.org/2006/time#unitWeek"/>
                    <rdf:Description rdf:about="http://www.w3.org/2006/time#unitYear"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:label>TemporalUnit</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/2006/time#Year -->

    <owl:Class rdf:about="http://www.w3.org/2006/time#Year">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2006/time#DurationDescription"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2006/time#days"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2006/time#hours"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2006/time#minutes"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2006/time#months"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2006/time#seconds"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2006/time#weeks"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2006/time#years"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>Year</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/2006/zone#TimeZone -->

    <owl:Class rdf:about="http://www.w3.org/2006/zone#TimeZone">
        <rdfs:label>TimeZone</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/2007/uwa/ontologies/DeliveryContext.owl#AvailableNetworkBearer -->

    <owl:Class rdf:about="http://www.w3.org/2007/uwa/ontologies/DeliveryContext.owl#AvailableNetworkBearer">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2007/uwa/ontologies/DeliveryContext.owl#NetworkBearer"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2007/uwa/ontologies/DeliveryContext.owl#bearerNetwork"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>AvailableNetworkBearer</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/2007/uwa/ontologies/DeliveryContext.owl#BearerType -->

    <owl:Class rdf:about="http://www.w3.org/2007/uwa/ontologies/DeliveryContext.owl#BearerType">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2007/uwa/ontologies/DeliveryContext.owl#networkName"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>BearerType</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/2007/uwa/ontologies/DeliveryContext.owl#MobileNetwork -->

    <owl:Class rdf:about="http://www.w3.org/2007/uwa/ontologies/DeliveryContext.owl#MobileNetwork">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2007/uwa/ontologies/DeliveryContext.owl#networkIdentifier"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2007/uwa/ontologies/DeliveryContext.owl#networkName"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>MobileNetwork</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/2007/uwa/ontologies/DeliveryContext.owl#NetworkBearer -->

    <owl:Class rdf:about="http://www.w3.org/2007/uwa/ontologies/DeliveryContext.owl#NetworkBearer">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2007/uwa/ontologies/DeliveryContext.owl#bearerType"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2007/uwa/ontologies/DeliveryContext.owl#networkMode"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>NetworkBearer</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/2007/uwa/ontologies/DeliveryContext.owl#NetworkEnvironment -->

    <owl:Class rdf:about="http://www.w3.org/2007/uwa/ontologies/DeliveryContext.owl#NetworkEnvironment">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2007/uwa/ontologies/DeliveryContext.owl#operatingNetworkBearer"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>NetworkEnvironment</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/2007/uwa/ontologies/DeliveryContext.owl#NetworkMode -->

    <owl:Class rdf:about="http://www.w3.org/2007/uwa/ontologies/DeliveryContext.owl#NetworkMode">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2007/uwa/ontologies/DeliveryContext.owl#networkType"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
