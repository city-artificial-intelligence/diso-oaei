    <!-- http://www.cenitmio.es/ontologies/Location.owl#City -->

    <owl:Class rdf:about="http://www.cenitmio.es/ontologies/Location.owl#City">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://pervasive.semanticweb.org/ont/2004/06/space#GeopoliticalEntity"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/Location.owl#hasGeoDirect"/>
                        <owl:someValuesFrom rdf:resource="http://www.cenitmio.es/ontologies/Location.owl#PostalDistrict"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/Location.owl#isPartOfGeoDirect"/>
                        <owl:someValuesFrom rdf:resource="http://www.cenitmio.es/ontologies/Location.owl#Province"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/Location.owl#isPartOfGeoDirect"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.cenitmio.es/ontologies/Location.owl#Province"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://www.cenitmio.es/ontologies/Location.owl#Country"/>
        <owl:disjointWith rdf:resource="http://www.cenitmio.es/ontologies/Location.owl#PostalDistrict"/>
        <owl:disjointWith rdf:resource="http://www.cenitmio.es/ontologies/Location.owl#Province"/>
        <rdfs:comment>Una ciudad es un objeto geopolítico que es parte de una o varias provincias (existen ciudades limítrofes que se encuentran entre dos provincias) y contiene uno o más distritos postales.</rdfs:comment>
        <rdfs:label xml:lang="en">City</rdfs:label>
        <rdfs:label xml:lang="es">Ciudad</rdfs:label>
    </owl:Class>
    


