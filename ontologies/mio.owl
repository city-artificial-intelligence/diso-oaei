    <!-- http://www.cenitmio.es/ontologies/Device.owl#Balise -->

    <owl:Class rdf:about="http://www.cenitmio.es/ontologies/Device.owl#Balise">
        <rdfs:subClassOf rdf:resource="http://www.cenitmio.es/ontologies/Device.owl#Device"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/mIO.owl#hasConnectionInterface"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Interface.owl#BluetoothConnectionInterface"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Interface.owl#RFConnectionInterface"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Interface.owl#VisualConnectionInterface"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Interface.owl#WiFiConnectionInterface"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Interface.owl#ZigbeeConnectionInterface"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="es">La baliza de localización o baliza sirve de ayuda para la localización.</rdfs:label>
    </owl:Class>
    


