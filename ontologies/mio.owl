    <!-- http://www.cenitmio.es/ontologies/Device.owl#EnvironmentalHumidityPressureSensor -->

    <owl:Class rdf:about="http://www.cenitmio.es/ontologies/Device.owl#EnvironmentalHumidityPressureSensor">
        <rdfs:subClassOf rdf:resource="http://www.cenitmio.es/ontologies/Device.owl#EnvironmentalHumiditySensor"/>
        <rdfs:subClassOf rdf:resource="http://www.cenitmio.es/ontologies/Device.owl#EnvironmentalPressureSensor"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/Source.owl#providesContextInformation"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Source.owl#InformationAboutHumidity"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Source.owl#InformationAboutPressure"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Source.owl#InformationAboutTemperature"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/mIO.owl#hasConnectionInterface"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Interface.owl#BluetoothConnectionInterface"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Interface.owl#RFConnectionInterface"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Interface.owl#VisualConnectionInterface"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Interface.owl#WiFiConnectionInterface"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Interface.owl#ZigbeeConnectionInterface"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Un sensor de humedad y presión ambiental mide datos atmosféricos. No tienen porqué estar contenidos en el mismo dispositivo. Pueden darse sensores sólo de humedad o sólo de presión.</rdfs:comment>
        <rdfs:label>EnvironmentalHumidityPressureSensor</rdfs:label>
    </owl:Class>
    


