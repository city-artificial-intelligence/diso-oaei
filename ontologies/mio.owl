    <!-- http://www.cenitmio.es/ontologies/Device.owl#Camera -->

    <owl:Class rdf:about="http://www.cenitmio.es/ontologies/Device.owl#Camera">
        <rdfs:subClassOf rdf:resource="http://www.cenitmio.es/ontologies/Device.owl#Device"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/mIO.owl#hasInterfaceWithModality"/>
                        <owl:someValuesFrom rdf:resource="http://www.cenitmio.es/ontologies/mIO.owl#NAryRelationHasInterfaceWithModality"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/componency.owl#hasComponent"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:unionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#Display"/>
                                    <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#ImageCaptureDevice"/>
                                    <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#ImageProcessingDevice"/>
                                    <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#Lens"/>
                                    <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#LightingDevice"/>
                                    <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#MemoryModule"/>
                                    <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#Microphone"/>
                                    <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#PositioningDevice"/>
                                </owl:unionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/Device.owl#isASharedDeviceReceivingImagenes"/>
                        <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:hasValue>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/Device.owl#isASharedDevideDuringControll"/>
                        <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</owl:hasValue>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/Device.owl#isCompatibleWithStandard"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:oneOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#DLNA"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#pictbridge"/>
                        </owl:oneOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/Device.owl#isConnectedWithDevice"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#Display"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#GPSReceiver"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#LargeDistanceCommunicationModule"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#Loudspeaker"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#MemoryModule"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#Printer"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#ProcessingModule"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#ReadingWritingModuleNFC"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#ShortDistanceCommunicationModule"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#TouchScreen"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/mIO.owl#hasConnectionInterface"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Interface.owl#BluetoothConnectionInterface"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Interface.owl#CompositeVideoConnectionInterface"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Interface.owl#FireWireConnectionInterface"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Interface.owl#HDMIConnectionInterface"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Interface.owl#MicConnectionInterface"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Interface.owl#USBConnectionInterface"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Interface.owl#WiFiConnectionInterface"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Una cámara proporciona un servicio de captura de imágenes, vídeo o ambos.</rdfs:comment>
        <rdfs:label>Camera</rdfs:label>
    </owl:Class>
    


