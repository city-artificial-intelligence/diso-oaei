        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Agent"/>
        <rdfs:comment>The birthday of this Agent, represented in mm-dd string form, eg. &apos;12-31&apos;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://xmlns.com/foaf/0.1/</rdfs:isDefinedBy>
        <rdfs:label>birthday</rdfs:label>
        <ns3:term_status>unstable</ns3:term_status>
    </owl:DatatypeProperty>
    


    <!-- http://xmlns.com/foaf/0.1/dnaChecksum -->

    <owl:DatatypeProperty rdf:about="http://xmlns.com/foaf/0.1/dnaChecksum">
        <rdfs:comment>A checksum for the DNA of some thing. Joke.</rdfs:comment>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://xmlns.com/foaf/0.1/</rdfs:isDefinedBy>
        <rdfs:label>DNA checksum</rdfs:label>
        <ns3:term_status>unstable</ns3:term_status>
    </owl:DatatypeProperty>
    


    <!-- http://xmlns.com/foaf/0.1/family_name -->

    <owl:DatatypeProperty rdf:about="http://xmlns.com/foaf/0.1/family_name">
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:comment>The family_name of some person.</rdfs:comment>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://xmlns.com/foaf/0.1/</rdfs:isDefinedBy>
        <rdfs:label>family_name</rdfs:label>
        <ns3:term_status>testing</ns3:term_status>
    </owl:DatatypeProperty>
    


    <!-- http://xmlns.com/foaf/0.1/firstName -->

    <owl:DatatypeProperty rdf:about="http://xmlns.com/foaf/0.1/firstName">
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:comment>The first name of a person.</rdfs:comment>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://xmlns.com/foaf/0.1/</rdfs:isDefinedBy>
        <rdfs:label>firstName</rdfs:label>
        <ns3:term_status>testing</ns3:term_status>
    </owl:DatatypeProperty>
    


    <!-- http://xmlns.com/foaf/0.1/geekcode -->

    <owl:DatatypeProperty rdf:about="http://xmlns.com/foaf/0.1/geekcode">
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:comment>A textual geekcode for this person, see http://www.geekcode.com/geek.html</rdfs:comment>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://xmlns.com/foaf/0.1/</rdfs:isDefinedBy>
        <rdfs:label>geekcode</rdfs:label>
        <ns3:term_status>testing</ns3:term_status>
    </owl:DatatypeProperty>
    


    <!-- http://xmlns.com/foaf/0.1/gender -->

    <owl:DatatypeProperty rdf:about="http://xmlns.com/foaf/0.1/gender">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Agent"/>
        <rdfs:comment>The gender of this Agent (typically but not necessarily &apos;male&apos; or &apos;female&apos;).</rdfs:comment>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://xmlns.com/foaf/0.1/</rdfs:isDefinedBy>
        <rdfs:label>gender</rdfs:label>
        <ns3:term_status>testing</ns3:term_status>
    </owl:DatatypeProperty>
    


    <!-- http://xmlns.com/foaf/0.1/givenname -->

    <owl:DatatypeProperty rdf:about="http://xmlns.com/foaf/0.1/givenname">
        <rdfs:comment>The given name of some person.</rdfs:comment>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://xmlns.com/foaf/0.1/</rdfs:isDefinedBy>
        <rdfs:label>Given name</rdfs:label>
        <ns3:term_status>testing</ns3:term_status>
    </owl:DatatypeProperty>
    


    <!-- http://xmlns.com/foaf/0.1/icqChatID -->

    <owl:DatatypeProperty rdf:about="http://xmlns.com/foaf/0.1/icqChatID">
        <rdfs:subPropertyOf rdf:resource="http://xmlns.com/foaf/0.1/nick"/>
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Agent"/>
        <rdfs:comment>An ICQ chat ID</rdfs:comment>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://xmlns.com/foaf/0.1/</rdfs:isDefinedBy>
        <rdfs:label>ICQ chat ID</rdfs:label>
        <ns3:term_status>testing</ns3:term_status>
    </owl:DatatypeProperty>
    


    <!-- http://xmlns.com/foaf/0.1/jabberID -->

    <owl:DatatypeProperty rdf:about="http://xmlns.com/foaf/0.1/jabberID">
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Agent"/>
        <rdfs:comment>A jabber ID for something.</rdfs:comment>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://xmlns.com/foaf/0.1/</rdfs:isDefinedBy>
        <rdfs:label>jabber ID</rdfs:label>
        <ns3:term_status>testing</ns3:term_status>
    </owl:DatatypeProperty>
    


    <!-- http://xmlns.com/foaf/0.1/mbox_sha1sum -->

    <owl:DatatypeProperty rdf:about="http://xmlns.com/foaf/0.1/mbox_sha1sum">
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Agent"/>
        <rdfs:comment>The sha1sum of the URI of an Internet mailbox associated with exactly one owner, the  first owner of the mailbox.</rdfs:comment>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://xmlns.com/foaf/0.1/</rdfs:isDefinedBy>
        <rdfs:label>sha1sum of a personal mailbox URI name</rdfs:label>
        <ns3:term_status>testing</ns3:term_status>
    </owl:DatatypeProperty>
    


    <!-- http://xmlns.com/foaf/0.1/msnChatID -->

    <owl:DatatypeProperty rdf:about="http://xmlns.com/foaf/0.1/msnChatID">
        <rdfs:subPropertyOf rdf:resource="http://xmlns.com/foaf/0.1/nick"/>
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Agent"/>
        <rdfs:comment>An MSN chat ID</rdfs:comment>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://xmlns.com/foaf/0.1/</rdfs:isDefinedBy>
        <rdfs:label>MSN chat ID</rdfs:label>
        <ns3:term_status>testing</ns3:term_status>
    </owl:DatatypeProperty>
    


    <!-- http://xmlns.com/foaf/0.1/name -->

    <owl:DatatypeProperty rdf:about="http://xmlns.com/foaf/0.1/name">
        <rdfs:comment>A name for some thing.</rdfs:comment>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://xmlns.com/foaf/0.1/</rdfs:isDefinedBy>
        <rdfs:label>name</rdfs:label>
        <ns3:term_status>testing</ns3:term_status>
    </owl:DatatypeProperty>
    


    <!-- http://xmlns.com/foaf/0.1/nick -->

    <owl:DatatypeProperty rdf:about="http://xmlns.com/foaf/0.1/nick">
        <rdfs:comment>A short informal nickname characterising an agent (includes login identifiers, IRC and other chat nicknames).</rdfs:comment>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://xmlns.com/foaf/0.1/</rdfs:isDefinedBy>
        <rdfs:label>nickname</rdfs:label>
        <ns3:term_status>testing</ns3:term_status>
    </owl:DatatypeProperty>
    


    <!-- http://xmlns.com/foaf/0.1/plan -->

    <owl:DatatypeProperty rdf:about="http://xmlns.com/foaf/0.1/plan">
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:comment>A .plan comment, in the tradition of finger and &apos;.plan&apos; files.</rdfs:comment>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://xmlns.com/foaf/0.1/</rdfs:isDefinedBy>
        <rdfs:label>plan</rdfs:label>
        <ns3:term_status>testing</ns3:term_status>
    </owl:DatatypeProperty>
    


    <!-- http://xmlns.com/foaf/0.1/sha1 -->

    <owl:DatatypeProperty rdf:about="http://xmlns.com/foaf/0.1/sha1">
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Document"/>
        <rdfs:comment>A sha1sum hash, in hex.</rdfs:comment>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://xmlns.com/foaf/0.1/</rdfs:isDefinedBy>
        <rdfs:label>sha1sum (hex)</rdfs:label>
        <ns3:term_status>unstable</ns3:term_status>
    </owl:DatatypeProperty>
    


    <!-- http://xmlns.com/foaf/0.1/surname -->

    <owl:DatatypeProperty rdf:about="http://xmlns.com/foaf/0.1/surname">
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:comment>The surname of some person.</rdfs:comment>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://xmlns.com/foaf/0.1/</rdfs:isDefinedBy>
        <rdfs:label>Surname</rdfs:label>
        <ns3:term_status>testing</ns3:term_status>
    </owl:DatatypeProperty>
    


    <!-- http://xmlns.com/foaf/0.1/title -->

    <owl:DatatypeProperty rdf:about="http://xmlns.com/foaf/0.1/title">
        <rdfs:comment>Title (Mr, Mrs, Ms, Dr. etc)</rdfs:comment>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://xmlns.com/foaf/0.1/</rdfs:isDefinedBy>
        <rdfs:label>title</rdfs:label>
        <ns3:term_status>testing</ns3:term_status>
    </owl:DatatypeProperty>
    


    <!-- http://xmlns.com/foaf/0.1/yahooChatID -->

    <owl:DatatypeProperty rdf:about="http://xmlns.com/foaf/0.1/yahooChatID">
        <rdfs:subPropertyOf rdf:resource="http://xmlns.com/foaf/0.1/nick"/>
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Agent"/>
        <rdfs:comment>A Yahoo chat ID</rdfs:comment>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://xmlns.com/foaf/0.1/</rdfs:isDefinedBy>
        <rdfs:label>Yahoo chat ID</rdfs:label>
        <ns3:term_status>testing</ns3:term_status>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#Apartment -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#Apartment">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#ApartmentBuilding"/>
        <rdfs:comment xml:lang="en">a relatively self-contained housing unit in a building.</rdfs:comment>
        <rdfs:label>Apartment</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#ApartmentBuilding -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#ApartmentBuilding">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#ResidentialBuilding"/>
        <rdfs:comment xml:lang="en">a multi-unit dwelling made up of several (generally four or more) apartments.</rdfs:comment>
        <rdfs:label>ApartmentBuilding</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#BoardingHouse -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#BoardingHouse">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#NonResidentialBuilding"/>
        <rdfs:comment xml:lang="en">A boarding house is a house (often a family home) in which holiday-makers or lodgers rent one or more rooms for one or more nights, and sometimes for extended periods of weeks, months and years</rdfs:comment>
        <rdfs:label>BoardingHouse</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#Building -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#Building">
        <rdfs:subClassOf rdf:resource="http://pervasive.semanticweb.org/ont/2004/06/space#FixedStructure"/>
        <rdfs:label>Building</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#Bungalow -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#Bungalow">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#ResidentialBuilding"/>
        <rdfs:comment xml:lang="en">A type of single story house.</rdfs:comment>
        <rdfs:label>Bungalow</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#Cafe -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#Cafe">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#NonResidentialBuilding"/>
        <rdfs:comment xml:lang="en">A coffeehouse, coffee shop, or cafe  shares some of the characteristics of a bar, and some of the characteristics of a restaurant. As the name suggests, coffeehouses focus on providing coffee and tea as well as light snacks.</rdfs:comment>
        <rdfs:label>Cafe</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#Caravan -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#Caravan">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#ResidentialBuilding"/>
        <rdfs:comment xml:lang="en">A caravan is a small trailer in which people can live and travel simultaneously.</rdfs:comment>
        <rdfs:label>Caravan</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#Church -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#Church">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#ReligiousBuilding"/>
        <rdfs:comment xml:lang="en">A building used in Christian worship.</rdfs:comment>
        <rdfs:label>Church</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#College -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#College">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#EducationBuilding"/>
        <rdfs:comment xml:lang="en">An educational institution.</rdfs:comment>
        <rdfs:label>College</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#Cottage -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#Cottage">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#ResidentialBuilding"/>
        <rdfs:comment xml:lang="en">A cottage is a dwelling, typically in a non-urban location (although there are cottage-style dwellings in cities).</rdfs:comment>
        <rdfs:label>Cottage</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#Depot -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#Depot">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#StorageBuilding"/>
        <rdfs:comment xml:lang="en">A depot is usually a centralized store or operating base for logistical use by commercial or governmental bodies.</rdfs:comment>
        <rdfs:label>Depot</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#Detached -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#Detached">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#ResidentialBuilding"/>
        <rdfs:comment xml:lang="en">A free-standing residential building, generally found in less dense urban areas, the suburbs of cities, the exurban region, and rural areas.</rdfs:comment>
        <rdfs:label>Detached</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#Dwelling -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#Dwelling">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#Building"/>
        <rdfs:label>Dwelling</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#EducationBuilding -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#EducationBuilding">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#NonResidentialBuilding"/>
        <rdfs:label>EducationBuilding</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#Factory -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#Factory">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#IndustrialBuilding"/>
        <rdfs:comment xml:lang="en">A factory or manufacturing plant is a large industrial building where workers manufacture goods or supervise machines processing one product into another.</rdfs:comment>
        <rdfs:label>Factory</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#Farm -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#Farm">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#NonResidentialBuilding"/>
        <rdfs:comment xml:lang="en">A farm is the basic unit in agriculture. It is a section of land devoted to the production and management of food, either produce or livestock.</rdfs:comment>
        <rdfs:label>Farm</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#Farmhouse -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#Farmhouse">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#ResidentialBuilding"/>
        <rdfs:comment xml:lang="en">A farmhouse is a type of building or house which serves a residential purpose in a rural or agricultural setting. Most often, the surrounding environment will be a farm.</rdfs:comment>
        <rdfs:label>Farmhouse</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#Garage -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#Garage">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#StorageBuilding"/>
        <rdfs:comment xml:lang="en">A building or part of a home either designed or used for storing a vehicle or vehicles.</rdfs:comment>
        <rdfs:label>Garage</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#Hospital -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#Hospital">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#NonResidentialBuilding"/>
        <rdfs:comment xml:lang="en">An institution for health care provided by physicians, surgeons, nurses, and other professionals.</rdfs:comment>
        <rdfs:label>Hospital</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#Hostel -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#Hostel">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#NonResidentialBuilding"/>
        <rdfs:comment xml:lang="en">Provide short-term accommodation to travellers or backpackers, particularly encouraging outdoor activities and cultural exchange for the young.</rdfs:comment>
        <rdfs:label>Hostel</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#Hotel -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#Hotel">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#NonResidentialBuilding"/>
        <owl:disjointWith rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#Motel"/>
        <rdfs:comment xml:lang="en">An establishment that provides paid lodging, usually on a short-term basis.</rdfs:comment>
        <rdfs:label>Hotel</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#House -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#House">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#ResidentialBuilding"/>
        <rdfs:label>House</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#IndustrialBuilding -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#IndustrialBuilding">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#NonResidentialBuilding"/>
        <rdfs:label>IndustrialBuilding</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#Maisonette -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#Maisonette">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#Apartment"/>
        <rdfs:comment xml:lang="en">an apartment / flat on two levels with internal stairs, or which has its own entrance at street level.</rdfs:comment>
        <rdfs:label>Maisonette</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#Mews -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#Mews">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#ResidentialBuilding"/>
        <rdfs:comment xml:lang="en">British term referring to a certain type of stabling with living quarters. The term is both singular (&quot;a mews house&quot;) and plural, and is used primarily in London and in some parts of Canada.</rdfs:comment>
        <rdfs:label>Mews</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#Motel -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#Motel">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#NonResidentialBuilding"/>
        <rdfs:comment xml:lang="en">The word motel (from MOtor hoTEL) referred initially to a single building of connected rooms whose doors face a parking lot and/or common area or a series of small cabins with common parking. Their creation was driven by increased driving distances on the United States highway system that allowed easy cross-country travel.</rdfs:comment>
        <rdfs:label>Motel</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#MultiStory -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#MultiStory">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#Building"/>
        <rdfs:comment xml:lang="en">a building with more than one story (floor)</rdfs:comment>
        <rdfs:label>MultiStory</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#NonResidentialBuilding -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#NonResidentialBuilding">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#Building"/>
        <owl:disjointWith rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#ResidentialBuilding"/>
        <rdfs:comment xml:lang="en">a building which is not used as a residence.</rdfs:comment>
        <rdfs:label>NonResidentialBuilding</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#NursingHome -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#NursingHome">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#NonResidentialBuilding"/>
        <rdfs:comment xml:lang="en">A place of residence for people who require constant nursing care and have significant Activity of Daily Living (ADL) deficiencies. Residents include the elderly and younger adults with physical disabilities.</rdfs:comment>
        <rdfs:label>NursingHome</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#OfficeBuilding -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#OfficeBuilding">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#NonResidentialBuilding"/>
        <rdfs:comment xml:lang="en">An office building  is a form of commercial building which contains spaces mainly designed to be used for offices. The primary purpose of an office building is to provide a workplace and working environment primarily for administrative and managerial workers.</rdfs:comment>
        <rdfs:label>OfficeBuilding</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#Penthouse -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#Penthouse">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#ResidentialBuilding"/>
        <rdfs:comment xml:lang="en">the top floor of a multi-story building</rdfs:comment>
        <rdfs:label>Penthouse</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#PowerPlant -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#PowerPlant">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#IndustrialBuilding"/>
        <rdfs:comment xml:lang="en">A facility for the generation of electric power.</rdfs:comment>
        <rdfs:label>PowerPlant</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#Prefabricated -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#Prefabricated">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#ResidentialBuilding"/>
        <rdfs:comment xml:lang="en">Houses built in modules (modular homes) or transportable sections (manufactured homes).</rdfs:comment>
        <rdfs:label>Prefabricated</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#Refinery -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#Refinery">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#IndustrialBuilding"/>
        <rdfs:comment xml:lang="en">Is composed of a group of chemical engineering unit processes and unit operations used for refining certain materials or converting raw material into products of value.</rdfs:comment>
        <rdfs:label>Refinery</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#ReligiousBuilding -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#ReligiousBuilding">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#NonResidentialBuilding"/>
        <rdfs:label>ReligiousBuilding</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#ResidentialBuilding -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#ResidentialBuilding">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#Building"/>
        <rdfs:comment xml:lang="en">a buidling which is constructed for residential occupancy. Its main purpose is to provide dwelling for one or more households</rdfs:comment>
        <rdfs:label>ResidentialBuilding</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#Restaurant -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#Restaurant">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#NonResidentialBuilding"/>
        <rdfs:comment xml:lang="en">An establishment that serves prepared food and beverages to be consumed on the premises.</rdfs:comment>
        <rdfs:label>Restaurant</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#School -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#School">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#EducationBuilding"/>
        <rdfs:comment xml:lang="en">A place designated for education in the form of group learning among students, teachers, and staff.</rdfs:comment>
        <rdfs:label>School</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#Semi-detached -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#Semi-detached">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#ResidentialBuilding"/>
        <rdfs:comment xml:lang="en">Semi-detached housing consists of pairs of houses built side by side as units sharing a party wall and usually in such a way that each house&apos;s layout is a mirror image of its twin.</rdfs:comment>
        <rdfs:label>Semi-detached</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#Shed -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#Shed">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#StorageBuilding"/>
        <rdfs:comment xml:lang="en">A simple, single-story structure in a back garden or on an allotment that is used for storage, hobbies or as a workshop.</rdfs:comment>
        <rdfs:label>Shed</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#Shop -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#Shop">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#NonResidentialBuilding"/>
        <rdfs:comment xml:lang="en">A mercantile establishment for the retail sale of goods or services</rdfs:comment>
        <rdfs:label>Shop</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#StorageBuilding -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#StorageBuilding">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#NonResidentialBuilding"/>
        <rdfs:comment xml:lang="en">A building or collections of buildings, designed to hold large objects, or a great many objects of a particular type.</rdfs:comment>
        <rdfs:label>StorageBuilding</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#Studio -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#Studio">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#Apartment"/>
        <rdfs:comment xml:lang="en">A self-contained unit with one main room, one bathroom, and some closet space. There is no distinct bedroom in a studio: sleeping, cooking, dining, living is all done in the main room.</rdfs:comment>
        <rdfs:label>Studio</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#Tavern -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#Tavern">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#NonResidentialBuilding"/>
        <rdfs:comment xml:lang="en">A tavern is, loosely, a place of business where people gather to drink alcoholic beverages and, more than likely, also be served food, though not licenced to put up guests.</rdfs:comment>
        <rdfs:label>Tavern</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#Terraced -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#Terraced">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#ResidentialBuilding"/>
        <rdfs:comment xml:lang="en">Is a style of housing where a row of identical or mirror-image houses share side walls. The first and last of these houses is called an end terrace.</rdfs:comment>
        <rdfs:label>Terraced</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#University -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#University">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#EducationBuilding"/>
        <rdfs:comment xml:lang="en">An institution of higher education and research, which grants academic degrees at all levels (bachelor, master, and doctorate) in a variety of subjects.</rdfs:comment>
        <rdfs:label>University</rdfs:label>
    </owl:Class>
    


    <!-- http://e-response.org/ontology/2006/20060815/e_response_buildings#Warehouse -->

    <owl:Class rdf:about="http://e-response.org/ontology/2006/20060815/e_response_buildings#Warehouse">
        <rdfs:subClassOf rdf:resource="http://e-response.org/ontology/2006/20060815/e_response_buildings#StorageBuilding"/>
        <rdfs:comment xml:lang="en">A commercial building for storage of goods.</rdfs:comment>
        <rdfs:label>Warehouse</rdfs:label>
    </owl:Class>
    


    <!-- http://ontologies.ezweb.morfeo-project.org/profile.owl#Profile -->

    <owl:Class rdf:about="http://ontologies.ezweb.morfeo-project.org/profile.owl#Profile">
        <owl:equivalentClass rdf:resource="http://ontologies.ezweb.morfeo-project.org/reco.owl#Profile"/>
        <rdfs:label>Profile</rdfs:label>
    </owl:Class>
    


    <!-- http://ontologies.ezweb.morfeo-project.org/profile.owl#Role -->

    <owl:Class rdf:about="http://ontologies.ezweb.morfeo-project.org/profile.owl#Role">
        <owl:equivalentClass rdf:resource="http://www.cenitmio.es/ontologies/Role.owl#Role"/>
        <rdfs:label>Role</rdfs:label>
    </owl:Class>
    


    <!-- http://ontologies.ezweb.morfeo-project.org/profile.owl#Situation -->

    <owl:Class rdf:about="http://ontologies.ezweb.morfeo-project.org/profile.owl#Situation">
        <rdfs:label>Situation</rdfs:label>
    </owl:Class>
    


    <!-- http://ontologies.ezweb.morfeo-project.org/reco.owl#CompositePreference -->

    <owl:Class rdf:about="http://ontologies.ezweb.morfeo-project.org/reco.owl#CompositePreference">
        <rdfs:subClassOf rdf:resource="http://ontologies.ezweb.morfeo-project.org/reco.owl#Preference"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <owl:Class>
                                <owl:complementOf>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://ontologies.ezweb.morfeo-project.org/reco.owl#andComposite"/>
                                        <owl:someValuesFrom rdf:resource="http://ontologies.ezweb.morfeo-project.org/reco.owl#Preference"/>
                                    </owl:Restriction>
                                </owl:complementOf>
                            </owl:Class>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://ontologies.ezweb.morfeo-project.org/reco.owl#unionComposite"/>
                                <owl:someValuesFrom rdf:resource="http://ontologies.ezweb.morfeo-project.org/reco.owl#Preference"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <owl:Class>
                                <owl:complementOf>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://ontologies.ezweb.morfeo-project.org/reco.owl#unionComposite"/>
                                        <owl:someValuesFrom rdf:resource="http://ontologies.ezweb.morfeo-project.org/reco.owl#Preference"/>
                                    </owl:Restriction>
                                </owl:complementOf>
                            </owl:Class>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://ontologies.ezweb.morfeo-project.org/reco.owl#andComposite"/>
                                <owl:someValuesFrom rdf:resource="http://ontologies.ezweb.morfeo-project.org/reco.owl#Preference"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:unionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A complex representation of a preference to express the union or the intersection of two or more preferences using AND and OR operators. A composite preference uses one and only one operator. Both operators are incompatible.</rdfs:comment>
        <rdfs:label xml:lang="en">Composite preference</rdfs:label>
    </owl:Class>
    


    <!-- http://ontologies.ezweb.morfeo-project.org/reco.owl#Demand -->

    <owl:Class rdf:about="http://ontologies.ezweb.morfeo-project.org/reco.owl#Demand">
        <rdfs:subClassOf rdf:resource="http://ontologies.ezweb.morfeo-project.org/reco.owl#ModalDescription"/>
        <rdfs:comment xml:lang="en">The willingness to achieve a commodity or a service with certain properties. Basically a demand is a set of preferences: mandatory, positive, negative or excluding.</rdfs:comment>
        <rdfs:label xml:lang="en">Demand</rdfs:label>
    </owl:Class>
    


    <!-- http://ontologies.ezweb.morfeo-project.org/reco.owl#Filter -->

    <owl:Class rdf:about="http://ontologies.ezweb.morfeo-project.org/reco.owl#Filter">
        <rdfs:comment xml:lang="en">A preferred condition on a datatype property.</rdfs:comment>
        <rdfs:label xml:lang="en">Filter</rdfs:label>
    </owl:Class>
    


    <!-- http://ontologies.ezweb.morfeo-project.org/reco.owl#ModalDescription -->

    <owl:Class rdf:about="http://ontologies.ezweb.morfeo-project.org/reco.owl#ModalDescription">
        <rdfs:comment xml:lang="en">A modal description consists in the specification of a modal target: desire, right, power, duty, etc. From the formal semantic viewpoint, a modal description is the reification of a relation involving a modal logic operator.</rdfs:comment>
        <rdfs:label xml:lang="en">Modal Description</rdfs:label>
    </owl:Class>
    


    <!-- http://ontologies.ezweb.morfeo-project.org/reco.owl#Operator -->

    <owl:Class rdf:about="http://ontologies.ezweb.morfeo-project.org/reco.owl#Operator">
        <rdfs:comment xml:lang="en">Elements that define operations on literals in a filter: string comparisons, numerical ranges, etc. Operators are equivalent to their corresponding SPARQL built-ins.</rdfs:comment>
        <rdfs:label xml:lang="en">Operator</rdfs:label>
    </owl:Class>
    


    <!-- http://ontologies.ezweb.morfeo-project.org/reco.owl#Pattern -->

    <owl:Class rdf:about="http://ontologies.ezweb.morfeo-project.org/reco.owl#Pattern">
        <rdfs:comment xml:lang="en">An individual that satisfies some preferred conditions. These individuals can be interpreted as variables in matchmaking applications.</rdfs:comment>
        <rdfs:label xml:lang="en">Pattern</rdfs:label>
    </owl:Class>
    


    <!-- http://ontologies.ezweb.morfeo-project.org/reco.owl#Preference -->

    <owl:Class rdf:about="http://ontologies.ezweb.morfeo-project.org/reco.owl#Preference">
        <rdfs:subClassOf rdf:resource="http://ontologies.ezweb.morfeo-project.org/reco.owl#ModalDescription"/>
        <rdfs:comment xml:lang="en">A desired property of a commodity or a service.</rdfs:comment>
        <rdfs:label xml:lang="en">Preference</rdfs:label>
    </owl:Class>
    


    <!-- http://ontologies.ezweb.morfeo-project.org/reco.owl#Profile -->

    <owl:Class rdf:about="http://ontologies.ezweb.morfeo-project.org/reco.owl#Profile">
        <owl:equivalentClass rdf:resource="http://www.cenitmio.es/ontologies/Role.owl#Profile"/>
        <rdfs:comment xml:lang="en">The user profile of an agent. An agent might have more than one profile: user profiles vary according to their contexts and situations.</rdfs:comment>
        <rdfs:label xml:lang="en">Profile</rdfs:label>
    </owl:Class>
    


    <!-- http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#AreaUnit -->

    <owl:Class rdf:about="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#AreaUnit">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#CentimeterSq"/>
                    <rdf:Description rdf:about="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#FootSq"/>
                    <rdf:Description rdf:about="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#InchSq"/>
                    <rdf:Description rdf:about="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#KilometerSq"/>
                    <rdf:Description rdf:about="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#MeterSq"/>
                    <rdf:Description rdf:about="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#MileSq"/>
                    <rdf:Description rdf:about="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#YardSq"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:label>AreaUnit</rdfs:label>
    </owl:Class>
    


    <!-- http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#AreaValueDescription -->

    <owl:Class rdf:about="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#AreaValueDescription">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#areaUnit"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#areaValue"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>AreaValueDescription</rdfs:label>
    </owl:Class>
    


    <!-- http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#Direction -->

    <owl:Class rdf:about="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#Direction">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#E"/>
                    <rdf:Description rdf:about="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#N"/>
                    <rdf:Description rdf:about="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#NE"/>
                    <rdf:Description rdf:about="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#NW"/>
                    <rdf:Description rdf:about="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#S"/>
                    <rdf:Description rdf:about="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#SE"/>
                    <rdf:Description rdf:about="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#SW"/>
                    <rdf:Description rdf:about="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#W"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:label>Direction</rdfs:label>
    </owl:Class>
    


    <!-- http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#Distance -->

    <owl:Class rdf:about="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#Distance">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#distanceValueDescription"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#fromSpatialThing"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#toSpatialThing"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>Distance</rdfs:label>
    </owl:Class>
    


    <!-- http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#DistanceUnit -->

    <owl:Class rdf:about="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#DistanceUnit">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#Centimeter"/>
                    <rdf:Description rdf:about="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#Foot"/>
                    <rdf:Description rdf:about="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#Inch"/>
                    <rdf:Description rdf:about="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#Kilometer"/>
                    <rdf:Description rdf:about="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#Meter"/>
                    <rdf:Description rdf:about="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#Mile"/>
                    <rdf:Description rdf:about="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#Yard"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:label>DistanceUnit</rdfs:label>
    </owl:Class>
    


    <!-- http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#DistanceValueDescription -->

    <owl:Class rdf:about="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#DistanceValueDescription">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#distanceUnit"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#direction"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#distanceValue"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>DistanceValueDescription</rdfs:label>
    </owl:Class>
    


    <!-- http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#LocationCoordinates -->

    <owl:Class rdf:about="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#LocationCoordinates">
        <rdfs:subClassOf rdf:resource="http://www.cenitmio.es/ontologies/Location.owl#AbsoluteLocationInformation"/>
        <rdfs:label>LocationCoordinates</rdfs:label>
    </owl:Class>
    


    <!-- http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#SurfaceArea -->

    <owl:Class rdf:about="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#SurfaceArea">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#areaValueDescription"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://pervasive.semanticweb.org/ont/2004/06/geo-measurement#surfaceAreaOf"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>SurfaceArea</rdfs:label>
    </owl:Class>
    


    <!-- http://pervasive.semanticweb.org/ont/2004/06/space#FixedStructure -->

    <owl:Class rdf:about="http://pervasive.semanticweb.org/ont/2004/06/space#FixedStructure">
        <rdfs:subClassOf rdf:resource="http://pervasive.semanticweb.org/ont/2004/06/space#GeographicalSpace"/>
        <owl:disjointWith rdf:resource="http://pervasive.semanticweb.org/ont/2004/06/space#GeographicalRegion"/>
        <owl:disjointWith rdf:resource="http://pervasive.semanticweb.org/ont/2004/06/space#SpaceInAFixedStructure"/>
        <rdfs:label>FixedStructure</rdfs:label>
    </owl:Class>
    


    <!-- http://pervasive.semanticweb.org/ont/2004/06/space#GeographicalRegion -->

    <owl:Class rdf:about="http://pervasive.semanticweb.org/ont/2004/06/space#GeographicalRegion">
        <owl:equivalentClass>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://pervasive.semanticweb.org/ont/2004/06/space#LandBasedRegion"/>
                    <rdf:Description rdf:about="http://pervasive.semanticweb.org/ont/2004/06/space#WaterBasedRegion"/>
                </owl:unionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://pervasive.semanticweb.org/ont/2004/06/space#GeographicalSpace"/>
        <owl:disjointWith rdf:resource="http://pervasive.semanticweb.org/ont/2004/06/space#SpaceInAFixedStructure"/>
        <rdfs:label>GeographicalRegion</rdfs:label>
    </owl:Class>
    


    <!-- http://pervasive.semanticweb.org/ont/2004/06/space#GeographicalSpace -->

    <owl:Class rdf:about="http://pervasive.semanticweb.org/ont/2004/06/space#GeographicalSpace">
        <owl:equivalentClass>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://pervasive.semanticweb.org/ont/2004/06/space#FixedStructure"/>
                    <rdf:Description rdf:about="http://pervasive.semanticweb.org/ont/2004/06/space#GeographicalRegion"/>
                    <rdf:Description rdf:about="http://pervasive.semanticweb.org/ont/2004/06/space#SpaceInAFixedStructure"/>
                </owl:unionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://pervasive.semanticweb.org/ont/2004/06/space#SpatialThing"/>
        <owl:disjointWith rdf:resource="http://pervasive.semanticweb.org/ont/2004/06/space#MovableSpatialThing"/>
        <rdfs:label>GeographicalSpace</rdfs:label>
    </owl:Class>
    


    <!-- http://pervasive.semanticweb.org/ont/2004/06/space#GeopoliticalEntity -->

    <owl:Class rdf:about="http://pervasive.semanticweb.org/ont/2004/06/space#GeopoliticalEntity">
        <owl:equivalentClass>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Location.owl#AutonomousRegion"/>
                    <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Location.owl#City"/>
                    <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Location.owl#Country"/>
                    <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Location.owl#PostalDistrict"/>
                    <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Location.owl#Province"/>
                </owl:unionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment>Un objeto geopolítico es una entidad geográfica debida a la intervención humana. Sólo puede ser uno de los siguientes elementos: país, comunidad autónoma, provincia, ciudad o distrito postal. Además, estos elementos son disjuntos entre sí.</rdfs:comment>
        <rdfs:label xml:lang="en">Geopolitical entity</rdfs:label>
        <rdfs:label xml:lang="es">Límite administrativo</rdfs:label>
    </owl:Class>
    


    <!-- http://pervasive.semanticweb.org/ont/2004/06/space#LandBasedRegion -->

    <owl:Class rdf:about="http://pervasive.semanticweb.org/ont/2004/06/space#LandBasedRegion">
        <rdfs:subClassOf rdf:resource="http://pervasive.semanticweb.org/ont/2004/06/space#GeographicalRegion"/>
        <owl:disjointWith rdf:resource="http://pervasive.semanticweb.org/ont/2004/06/space#WaterBasedRegion"/>
        <rdfs:label>LandBasedRegion</rdfs:label>
    </owl:Class>
    


    <!-- http://pervasive.semanticweb.org/ont/2004/06/space#MovableSpatialThing -->

    <owl:Class rdf:about="http://pervasive.semanticweb.org/ont/2004/06/space#MovableSpatialThing">
        <rdfs:subClassOf rdf:resource="http://pervasive.semanticweb.org/ont/2004/06/space#SpatialThing"/>
        <rdfs:label>MovableSpatialThing</rdfs:label>
    </owl:Class>
    


    <!-- http://pervasive.semanticweb.org/ont/2004/06/space#SpaceInAFixedStructure -->

    <owl:Class rdf:about="http://pervasive.semanticweb.org/ont/2004/06/space#SpaceInAFixedStructure">
        <rdfs:subClassOf rdf:resource="http://pervasive.semanticweb.org/ont/2004/06/space#GeographicalSpace"/>
        <rdfs:label>SpaceInAFixedStructure</rdfs:label>
    </owl:Class>
    


    <!-- http://pervasive.semanticweb.org/ont/2004/06/space#SpatialThing -->

    <owl:Class rdf:about="http://pervasive.semanticweb.org/ont/2004/06/space#SpatialThing">
        <owl:equivalentClass>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://pervasive.semanticweb.org/ont/2004/06/space#GeographicalSpace"/>
                    <rdf:Description rdf:about="http://pervasive.semanticweb.org/ont/2004/06/space#MovableSpatialThing"/>
                </owl:unionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/Location.owl#hasAddress"/>
                <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/Location.owl#hasLocation"/>
                <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>SpatialThing</rdfs:label>
    </owl:Class>
    


    <!-- http://pervasive.semanticweb.org/ont/2004/06/space#WaterBasedRegion -->

    <owl:Class rdf:about="http://pervasive.semanticweb.org/ont/2004/06/space#WaterBasedRegion">
