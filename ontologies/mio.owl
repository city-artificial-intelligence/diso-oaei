    <!-- http://www.cenitmio.es/ontologies/Device.owl#PulseOximeter -->

    <owl:Class rdf:about="http://www.cenitmio.es/ontologies/Device.owl#PulseOximeter">
        <rdfs:subClassOf rdf:resource="http://www.cenitmio.es/ontologies/Device.owl#Device"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/Device.owl#isConnectedWithDevice"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#MobileDevice"/>
                            <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Device.owl#PersonalComputer"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/mIO.owl#hasConnectionInterface"/>
                <owl:allValuesFrom rdf:resource="http://www.cenitmio.es/ontologies/Interface.owl#WirelessConnectionInterface"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Normalmente los pulsioxímetros se colocan en el dedo índice, aunque un método cada vez más empleado es usarlo en el lóbulo de la oreja.
Un pulsioxímetro funciona mejor en personas de raza blanca pues la piel negra es un obstáculo para la luz, por su absorción.</rdfs:comment>
        <rdfs:comment xml:lang="en">Usually pulse oximeters are placed on the index finger, although an increasingly used method is to use it in the earlobe.</rdfs:comment>
        <rdfs:label>PulseOximeter</rdfs:label>
    </owl:Class>
    


    <!-- http://www.cenitmio.es/ontologies/Device.owl#RAMMemoryModule -->

    <owl:Class rdf:about="http://www.cenitmio.es/ontologies/Device.owl#RAMMemoryModule">
