        <rdfs:label xml:lang="en">RAMMemoryModule</rdfs:label>
    </owl:Class>
    


    <!-- http://www.cenitmio.es/ontologies/Device.owl#RFIDLabel -->

    <owl:Class rdf:about="http://www.cenitmio.es/ontologies/Device.owl#RFIDLabel">
        <rdfs:subClassOf rdf:resource="http://www.cenitmio.es/ontologies/Device.owl#Device"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/mIO.owl#isDeviceIncludedIn"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://pervasive.semanticweb.org/ont/2004/06/space#SpatialThing"/>
                            <rdf:Description rdf:about="http://www.ontologydesignpatterns.org/cp/owl/componency.owl#Object"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/Device.owl#rFIDLabelEnergyConsumption"/>
                <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.0</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Una etiqueta RFID sirve para identificar un objeto.
Una etiqueta RFID proporciona como dato el identificador asociado al objeto.
Una etiqueta RFID es detectada mejor si no se encuentra adherida a objetos con alto contenido en agua.
Una etiqueta RFID pasiva no consume batería</rdfs:comment>
        <rdfs:label xml:lang="en">RFIDLabel</rdfs:label>
    </owl:Class>
    


