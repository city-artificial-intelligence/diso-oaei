    <owl:Class rdf:about="http://www.cenitmio.es/ontologies/Provider.owl#ServiceProviderByCardinality">
        <owl:equivalentClass>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Provider.owl#MultipleServiceProvider"/>
                    <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Provider.owl#SimpleServiceProvider"/>
                </owl:unionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">This concept has been created to support the modelling of aggregate service provider.</rdfs:comment>
        <rdfs:label xml:lang="es">Proveedor de servicio por cardinalidad</rdfs:label>
        <rdfs:label xml:lang="en">Service provider by cardinality</rdfs:label>
    </owl:Class>
    


