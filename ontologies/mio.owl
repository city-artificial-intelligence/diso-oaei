    <!-- http://www.cenitmio.es/ontologies/Interface.owl#MixedInterface -->

    <owl:Class rdf:about="http://www.cenitmio.es/ontologies/Interface.owl#MixedInterface">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.cenitmio.es/ontologies/Interface.owl#Interface"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/Interface.owl#hasInterfaceType"/>
                        <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">2</owl:minCardinality>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.cenitmio.es/ontologies/Interface.owl#Interface"/>
        <rdfs:comment xml:lang="en">A mixed interface is a interface that have al least two interface types.</rdfs:comment>
        <rdfs:label xml:lang="es">Interfaz mixta</rdfs:label>
        <rdfs:label xml:lang="en">Mixed interface</rdfs:label>
    </owl:Class>
    


