    <!-- http://www.cenitmio.es/ontologies/Location.owl#AutonomousRegion -->

    <owl:Class rdf:about="http://www.cenitmio.es/ontologies/Location.owl#AutonomousRegion">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://pervasive.semanticweb.org/ont/2004/06/space#GeopoliticalEntity"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/Location.owl#hasGeoDirect"/>
                        <owl:someValuesFrom rdf:resource="http://www.cenitmio.es/ontologies/Location.owl#Province"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/Location.owl#isPartOfGeoDirect"/>
                        <owl:someValuesFrom rdf:resource="http://www.cenitmio.es/ontologies/Location.owl#Country"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.cenitmio.es/ontologies/Location.owl#isPartOfGeoDirect"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.cenitmio.es/ontologies/Location.owl#Country"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://www.cenitmio.es/ontologies/Location.owl#City"/>
        <owl:disjointWith rdf:resource="http://www.cenitmio.es/ontologies/Location.owl#Country"/>
        <owl:disjointWith rdf:resource="http://www.cenitmio.es/ontologies/Location.owl#PostalDistrict"/>
        <owl:disjointWith rdf:resource="http://www.cenitmio.es/ontologies/Location.owl#Province"/>
        <rdfs:comment>Comunidad autónoma es un objeto geopolítico que es parte de un solo país y tiene una o varias provincias.</rdfs:comment>
        <rdfs:label xml:lang="en">Autonomous region</rdfs:label>
        <rdfs:label xml:lang="es">Comunidad autónoma</rdfs:label>
    </owl:Class>
    


